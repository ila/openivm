# name: test/sql/ducklake_left_join.test
# description: Test IVM left joins with DuckLake base tables
# group: [sql]

require openivm

require parquet

statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
SET openivm_files_path='__TEST_DIR__';

statement ok
ATTACH '__TEST_DIR__/ducklake_left_join.db' AS dl (TYPE ducklake);

# ==========================================
# Basic LEFT JOIN
# ==========================================

statement ok
CREATE TABLE dl.customers (id INTEGER, name VARCHAR);

statement ok
CREATE TABLE dl.orders (id INTEGER, cust_id INTEGER, amount DECIMAL(10,2));

statement ok
INSERT INTO dl.customers VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');

statement ok
INSERT INTO dl.orders VALUES (1, 1, 100.00), (2, 1, 50.00), (3, 2, 75.00);

statement ok
CREATE MATERIALIZED VIEW dl.mv_cust_orders AS
  SELECT c.name, SUM(o.amount) as total, COUNT(o.amount) as cnt
  FROM dl.customers c LEFT JOIN dl.orders o ON c.id = o.cust_id
  GROUP BY c.name;

query III rowsort
SELECT * FROM dl.mv_cust_orders ORDER BY name;
----
Alice	150.00	2
Bob	75.00	1
Carol	NULL	0

# EXCEPT ALL
query I
SELECT count(*) FROM (
  SELECT name, total, cnt FROM dl.mv_cust_orders
  EXCEPT ALL
  SELECT c.name, SUM(o.amount), COUNT(o.amount) FROM dl.customers c LEFT JOIN dl.orders o ON c.id = o.cust_id GROUP BY c.name
);
----
0

query I
SELECT count(*) FROM (
  SELECT c.name, SUM(o.amount), COUNT(o.amount) FROM dl.customers c LEFT JOIN dl.orders o ON c.id = o.cust_id GROUP BY c.name
  EXCEPT ALL
  SELECT name, total, cnt FROM dl.mv_cust_orders
);
----
0

# ==========================================
# Qualified source pushdown
# ==========================================

statement ok
CREATE TABLE dl.lj_accounts(id INT, name VARCHAR);

statement ok
CREATE TABLE dl.lj_items(item_id INT, account_id INT, label VARCHAR);

statement ok
CREATE TABLE dl.lj_metrics(item_id INT, metric INT);

statement ok
INSERT INTO dl.lj_accounts VALUES (1, 'A'), (2, 'B');

statement ok
INSERT INTO dl.lj_items VALUES (10, 1, 'x'), (20, 2, 'y');

statement ok
INSERT INTO dl.lj_metrics VALUES (10, 7);

statement ok
CREATE MATERIALIZED VIEW dl.mv_lj_qualified AS
  SELECT i.item_id, i.label, a.name, m.metric
  FROM dl.lj_accounts a
  JOIN dl.lj_items i ON a.id = i.account_id
  LEFT JOIN dl.lj_metrics m ON i.item_id = m.item_id;

statement ok
INSERT INTO dl.lj_metrics VALUES (20, 8);

statement ok
INSERT INTO dl.lj_items VALUES (30, 1, 'z');

statement ok
DELETE FROM dl.lj_metrics WHERE item_id = 10;

statement ok
PRAGMA refresh('mv_lj_qualified');

query I
SELECT contains(content, 'openivm_lj_src') AND contains(content, 'openivm_affected')
FROM read_text('__TEST_DIR__/openivm_upsert_queries_mv_lj_qualified.sql');
----
true

query I
SELECT contains(content, 'dl.main.lj_items')
FROM read_text('__TEST_DIR__/openivm_upsert_queries_mv_lj_qualified.sql');
----
true

query I
SELECT count(*) FROM (
  SELECT i.item_id, i.label, a.name, m.metric
  FROM dl.lj_accounts a
  JOIN dl.lj_items i ON a.id = i.account_id
  LEFT JOIN dl.lj_metrics m ON i.item_id = m.item_id
  EXCEPT ALL
  SELECT * FROM dl.mv_lj_qualified
);
----
0

query I
SELECT count(*) FROM (
  SELECT * FROM dl.mv_lj_qualified
  EXCEPT ALL
  SELECT i.item_id, i.label, a.name, m.metric
  FROM dl.lj_accounts a
  JOIN dl.lj_items i ON a.id = i.account_id
  LEFT JOIN dl.lj_metrics m ON i.item_id = m.item_id
);
----
0

# ==========================================
# Wrapped LEFT JOIN source: suppress child join key probes
# ==========================================

statement ok
CREATE TABLE dl.lj_probe_company(cid INT, cname VARCHAR);

statement ok
CREATE TABLE dl.lj_probe_security(sk INT, cid INT, sname VARCHAR);

statement ok
CREATE TABLE dl.lj_probe_market(sk INT, metric INT);

statement ok
INSERT INTO dl.lj_probe_company VALUES (10, 'Acme'), (20, 'Globex');

statement ok
INSERT INTO dl.lj_probe_security VALUES (1, 10, 'ACM'), (2, 20, 'GLX');

statement ok
INSERT INTO dl.lj_probe_market VALUES (1, 7);

statement ok
CREATE MATERIALIZED VIEW dl.mv_lj_probe AS
  SELECT l.sk, l.sname, l.cname, r.metric
  FROM (
    SELECT sec.sk, sec.sname, c.cname
    FROM dl.lj_probe_company c
    JOIN dl.lj_probe_security sec ON c.cid = sec.cid
  ) l
  LEFT JOIN (
    SELECT m.sk, m.metric
    FROM dl.lj_probe_market m
  ) r ON l.sk = r.sk;

statement ok
SET openivm_profile_refresh = true;

statement ok
INSERT INTO dl.lj_probe_security VALUES (3, 10, 'ACM2');

statement ok
PRAGMA refresh('mv_lj_probe');

query I
SELECT count(*) FROM openivm_refresh_profile
WHERE view_name = 'mv_lj_probe'
  AND step_name = 'generate_refresh_sql.compute_delta.ducklake_join.term.key_domain_probe';
----
0

query I
SELECT count(*) FROM openivm_refresh_profile
WHERE view_name = 'mv_lj_probe'
  AND step_name = 'generate_refresh_sql.compute_delta.ducklake_join.total'
  AND contains(detail, 'has_left_join=false')
  AND contains(detail, 'key_probe_suppressed=true');
----
2

statement ok
SET openivm_profile_refresh = false;

query I
SELECT count(*) FROM (
  SELECT l.sk, l.sname, l.cname, r.metric
  FROM (
    SELECT sec.sk, sec.sname, c.cname
    FROM dl.lj_probe_company c
    JOIN dl.lj_probe_security sec ON c.cid = sec.cid
  ) l
  LEFT JOIN (
    SELECT m.sk, m.metric
    FROM dl.lj_probe_market m
  ) r ON l.sk = r.sk
  EXCEPT ALL
  SELECT * FROM dl.mv_lj_probe
);
----
0

query I
SELECT count(*) FROM (
  SELECT * FROM dl.mv_lj_probe
  EXCEPT ALL
  SELECT l.sk, l.sname, l.cname, r.metric
  FROM (
    SELECT sec.sk, sec.sname, c.cname
    FROM dl.lj_probe_company c
    JOIN dl.lj_probe_security sec ON c.cid = sec.cid
  ) l
  LEFT JOIN (
    SELECT m.sk, m.metric
    FROM dl.lj_probe_market m
  ) r ON l.sk = r.sk
);
----
0

# The MV delta table must be derived from the physical openivm_data_* table,
# not from planner output columns. LEFT JOIN rewrites may carry hidden lineage
# columns that do not survive into the stored data table.
query I
SELECT count(*) FROM (
  SELECT column_name, ordinal_position, data_type
  FROM information_schema.columns
  WHERE table_schema = 'main'
    AND table_name = 'openivm_data_mv_cust_orders'
  EXCEPT ALL
  SELECT column_name, ordinal_position, data_type
  FROM information_schema.columns
  WHERE table_schema = 'main'
    AND table_name = 'openivm_delta_mv_cust_orders'
    AND column_name NOT IN ('openivm_multiplicity', 'openivm_timestamp')
);
----
0

query I
SELECT count(*) FROM (
  SELECT column_name, ordinal_position, data_type
  FROM information_schema.columns
  WHERE table_schema = 'main'
    AND table_name = 'openivm_delta_mv_cust_orders'
    AND column_name NOT IN ('openivm_multiplicity', 'openivm_timestamp')
  EXCEPT ALL
  SELECT column_name, ordinal_position, data_type
  FROM information_schema.columns
  WHERE table_schema = 'main'
    AND table_name = 'openivm_data_mv_cust_orders'
);
----
0


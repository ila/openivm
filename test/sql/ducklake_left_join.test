# ==========================================
# Stress: batch INSERT + DELETE on both sides
# ==========================================

# Add new customer + order, delete existing order, add another order
statement ok
INSERT INTO dl.customers VALUES (4, 'Dave');

statement ok
INSERT INTO dl.orders VALUES (5, 4, 300.00);

statement ok
DELETE FROM dl.orders WHERE id = 2;

statement ok
INSERT INTO dl.orders VALUES (6, 1, 25.00);

statement ok
PRAGMA refresh('mv_cust_orders');

# EXCEPT ALL
query I
SELECT count(*) FROM (
  SELECT name, total, cnt FROM dl.mv_cust_orders
  EXCEPT ALL
  SELECT c.name, SUM(o.amount), COUNT(o.amount) FROM dl.customers c LEFT JOIN dl.orders o ON c.id = o.cust_id GROUP BY c.name
);
----
0

query I
SELECT count(*) FROM (
  SELECT c.name, SUM(o.amount), COUNT(o.amount) FROM dl.customers c LEFT JOIN dl.orders o ON c.id = o.cust_id GROUP BY c.name
  EXCEPT ALL
  SELECT name, total, cnt FROM dl.mv_cust_orders
);

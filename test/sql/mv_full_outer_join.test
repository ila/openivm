# ============================================================
# FULL OUTER JOIN aggregate with GROUP BY (group-recompute mode)
# ============================================================

statement ok
CREATE TABLE departments (id INT, dept VARCHAR);

statement ok
CREATE TABLE staff (id INT, dept_id INT, salary INT);

statement ok
INSERT INTO departments VALUES (1, 'Eng'), (2, 'Sales'), (3, 'HR');

statement ok
INSERT INTO staff VALUES (1, 1, 100), (2, 1, 200), (3, 4, 300);

statement ok
CREATE MATERIALIZED VIEW dept_stats AS
    SELECT d.dept, SUM(s.salary) AS total_sal, COUNT(s.salary) AS cnt
    FROM departments d FULL OUTER JOIN staff s ON d.id = s.dept_id
    GROUP BY d.dept;

# Initial check
query I
SELECT COUNT(*) FROM (
    SELECT d.dept, SUM(s.salary), COUNT(s.salary) FROM departments d FULL OUTER JOIN staff s ON d.id = s.dept_id GROUP BY d.dept
    EXCEPT ALL
    SELECT * FROM dept_stats
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM dept_stats
    EXCEPT ALL
    SELECT d.dept, SUM(s.salary), COUNT(s.salary) FROM departments d FULL OUTER JOIN staff s ON d.id = s.dept_id GROUP BY d.dept
);
----
0

# Insert staff into Sales (was unmatched-left, now matched)
statement ok
INSERT INTO staff VALUES (4, 2, 150);

statement ok
PRAGMA ivm('dept_stats');

query I

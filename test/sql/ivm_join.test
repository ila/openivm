# name: test/sql/ivm_join.test
# description: Test IVM with inner joins
# group: [sql]

require openivm

statement ok
CREATE TABLE IF NOT EXISTS _duckdb_ivm_views (view_name VARCHAR PRIMARY KEY, sql_string VARCHAR, type TINYINT, last_update TIMESTAMP);

statement ok
CREATE TABLE IF NOT EXISTS _duckdb_ivm_delta_tables (view_name VARCHAR, table_name VARCHAR, last_update TIMESTAMP, PRIMARY KEY(view_name, table_name));

# --- Base tables ---
statement ok
CREATE TABLE gods (uid INT, user_name VARCHAR);

statement ok
CREATE TABLE payments (from_uid INT, to_uid INT, amount INT);

statement ok
INSERT INTO gods VALUES (1, 'Apollo'), (2, 'Artemis'), (3, 'Dionysus'), (4, 'Poseidon'), (5, 'Zeus');

statement ok
INSERT INTO payments VALUES (1, 2, 1722), (2, 3, 53), (2, 5, 360), (3, 1, 80), (3, 2, 137), (3, 5, 83), (5, 1, 42), (1, 2, 222);

# ==========================================
# Test 1: Simple join projection
# ==========================================

statement ok
CREATE TABLE named_payments AS
    SELECT g.user_name, p.from_uid, p.to_uid, p.amount
    FROM gods g INNER JOIN payments p ON p.to_uid = g.uid;

statement ok
CREATE TABLE delta_named_payments AS SELECT *, true AS _duckdb_ivm_multiplicity FROM named_payments LIMIT 0;

statement ok
CREATE TABLE delta_gods AS SELECT *, true AS _duckdb_ivm_multiplicity, now()::timestamp AS _duckdb_ivm_timestamp FROM gods LIMIT 0;

statement ok
CREATE TABLE delta_payments AS SELECT *, true AS _duckdb_ivm_multiplicity, now()::timestamp AS _duckdb_ivm_timestamp FROM payments LIMIT 0;

statement ok
INSERT INTO _duckdb_ivm_views VALUES ('named_payments', 'select g.user_name, p.from_uid, p.to_uid, p.amount from gods as g inner join payments as p on p.to_uid = g.uid', 2, now()::timestamp);

statement ok
INSERT INTO _duckdb_ivm_delta_tables VALUES ('named_payments', 'delta_gods', '1970-01-01');

statement ok
INSERT INTO _duckdb_ivm_delta_tables VALUES ('named_payments', 'delta_payments', '1970-01-01');

# Insert a new payment to Apollo (uid 1)
statement ok
INSERT INTO delta_payments VALUES (3, 1, 30, true, now()::timestamp);

statement ok
PRAGMA ivm_options('memory', 'main', 'named_payments');

# named_payments should now have the new payment
query IIII
SELECT user_name, from_uid, to_uid, amount FROM named_payments WHERE from_uid = 3 AND to_uid = 1 ORDER BY amount;
----
Apollo	3	1	30
Apollo	3	1	80

# ==========================================
# Test 2: Delete via join
# ==========================================

statement ok
INSERT INTO delta_payments VALUES (5, 1, 42, false, now()::timestamp);

statement ok
PRAGMA ivm_options('memory', 'main', 'named_payments');

# The payment (5, 1, 42) to Apollo should be gone
query I
SELECT count(*) FROM named_payments WHERE from_uid = 5 AND to_uid = 1 AND amount = 42;
----
0

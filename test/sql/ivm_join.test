# name: test/sql/ivm_join.test
# description: Test IVM with inner joins
# group: [sql]

require openivm

# --- Base tables ---
statement ok
CREATE TABLE gods (uid INT, user_name VARCHAR);

statement ok
CREATE TABLE payments (from_uid INT, to_uid INT, amount INT);

statement ok
INSERT INTO gods VALUES (1, 'Apollo'), (2, 'Artemis'), (3, 'Dionysus'), (4, 'Poseidon'), (5, 'Zeus');

statement ok
INSERT INTO payments VALUES (1, 2, 1722), (2, 3, 53), (2, 5, 360), (3, 1, 80), (3, 2, 137), (3, 5, 83), (5, 1, 42), (1, 2, 222);

# ==========================================
# Simple join projection
# ==========================================

statement ok
create materialized view named_payments as (select g.user_name, p.from_uid, p.to_uid, p.amount from gods as g inner join payments as p on p.to_uid = g.uid);

# ==========================================
# Test 1: Insert on RIGHT side (payments)
# ==========================================

statement ok
INSERT INTO payments VALUES (3, 1, 30);

statement ok
pragma ivm('named_payments');

query IIII
SELECT user_name, from_uid, to_uid, amount FROM named_payments WHERE from_uid = 3 AND to_uid = 1 ORDER BY amount;
----
Apollo	3	1	30
Apollo	3	1	80

# ==========================================
# Test 2: Delete via join
# ==========================================

statement ok
DELETE FROM payments WHERE from_uid = 5 AND to_uid = 1 AND amount = 42;

statement ok
pragma ivm('named_payments');

query I
SELECT count(*) FROM named_payments WHERE from_uid = 5 AND to_uid = 1 AND amount = 42;
----
0

# ==========================================
# Test 3: Insert on LEFT side (gods table)
# ==========================================

statement ok
INSERT INTO gods VALUES (6, 'Hera');

statement ok
pragma ivm('named_payments');

# No payments reference uid 6 yet, so MV unchanged
query I
SELECT count(*) FROM named_payments WHERE user_name = 'Hera';
----
0

# Now add a payment TO the new god
statement ok
INSERT INTO payments VALUES (1, 6, 99);

statement ok
pragma ivm('named_payments');

query III
SELECT user_name, from_uid, amount FROM named_payments WHERE to_uid = 6;
----
Hera	1	99

# ==========================================
# Test 4: Insert on BOTH sides simultaneously
# ==========================================

statement ok
INSERT INTO gods VALUES (7, 'Athena');

statement ok
INSERT INTO payments VALUES (2, 7, 500);

statement ok
pragma ivm('named_payments');

query III
SELECT user_name, from_uid, amount FROM named_payments WHERE to_uid = 7;
----
Athena	2	500

# ==========================================
# Test 5: Delete from LEFT side
# ==========================================

statement ok
DELETE FROM gods WHERE uid = 6;

statement ok
pragma ivm('named_payments');

query I
SELECT count(*) FROM named_payments WHERE user_name = 'Hera';
----
0

# ==========================================
# Test 6: Simultaneous delete on BOTH sides
# ==========================================

query III
SELECT user_name, from_uid, amount FROM named_payments WHERE to_uid = 7;
----
Athena	2	500

statement ok
DELETE FROM gods WHERE uid = 7;

statement ok
DELETE FROM payments WHERE to_uid = 7;

statement ok
pragma ivm('named_payments');

query I
SELECT count(*) FROM named_payments WHERE user_name = 'Athena';
----
0

# ==========================================
# Test 7: Batch insert — multiple rows at once
# ==========================================

statement ok
INSERT INTO payments VALUES (1, 2, 10), (1, 2, 20), (1, 2, 30);

statement ok
pragma ivm('named_payments');

# Count all payments from 1 to 2 (original: 1722, 222 + new: 10, 20, 30)
query I
SELECT count(*) FROM named_payments WHERE from_uid = 1 AND to_uid = 2;
----
5

# ==========================================
# Test 8: No-op PRAGMA (no changes since last)
# ==========================================

statement ok
pragma ivm('named_payments');

query I
SELECT count(*) FROM named_payments WHERE from_uid = 1 AND to_uid = 2;
----
5

# ==========================================
# Test 9: Duplicate rows (same values inserted twice)
# ==========================================

statement ok
INSERT INTO payments VALUES (4, 5, 777);

statement ok
INSERT INTO payments VALUES (4, 5, 777);

statement ok
pragma ivm('named_payments');

query I
SELECT count(*) FROM named_payments WHERE from_uid = 4 AND to_uid = 5 AND amount = 777;
----
2

# ==========================================
# Test 10: Mixed insert + delete in same PRAGMA cycle
# ==========================================

statement ok
DELETE FROM payments WHERE from_uid = 4 AND to_uid = 5 AND amount = 777;

statement ok
INSERT INTO payments VALUES (1, 3, 999);

statement ok
pragma ivm('named_payments');

query I
SELECT count(*) FROM named_payments WHERE from_uid = 4 AND to_uid = 5 AND amount = 777;
----
0

query III
SELECT user_name, from_uid, amount FROM named_payments WHERE from_uid = 1 AND to_uid = 3;
----
Dionysus	1	999

# ==========================================
# Test 11: Insert on both sides + delete simultaneously
# ==========================================

statement ok
INSERT INTO gods VALUES (8, 'Ares');

statement ok
INSERT INTO payments VALUES (1, 8, 50);

statement ok
DELETE FROM payments WHERE from_uid = 1 AND to_uid = 3 AND amount = 999;

statement ok
pragma ivm('named_payments');

query III
SELECT user_name, from_uid, amount FROM named_payments WHERE to_uid = 8;
----
Ares	1	50

query I
SELECT count(*) FROM named_payments WHERE from_uid = 1 AND to_uid = 3 AND amount = 999;
----
0

# ==========================================
# Test 12: 3-table join
# ==========================================

statement ok
CREATE TABLE cities (city_id INT, city_name VARCHAR);

statement ok
INSERT INTO cities VALUES (1, 'Athens'), (2, 'Sparta'), (3, 'Thebes');

statement ok
CREATE TABLE god_cities (uid INT, city_id INT);

statement ok
INSERT INTO god_cities VALUES (1, 1), (2, 2), (3, 1), (5, 3);

statement ok
create materialized view god_locations as (select g.user_name, c.city_name from gods as g inner join god_cities as gc on gc.uid = g.uid inner join cities as c on c.city_id = gc.city_id);

query II
SELECT user_name, city_name FROM god_locations ORDER BY user_name;
----
Apollo	Athens
Artemis	Sparta
Dionysus	Athens
Zeus	Thebes

# Insert into middle table (god_cities)
statement ok
INSERT INTO god_cities VALUES (4, 2);

statement ok
pragma ivm('god_locations');

query II
SELECT user_name, city_name FROM god_locations WHERE user_name = 'Poseidon';
----
Poseidon	Sparta

# Insert into rightmost table (cities) + link table
statement ok
INSERT INTO cities VALUES (4, 'Corinth');

statement ok
INSERT INTO god_cities VALUES (1, 4);

statement ok
pragma ivm('god_locations');

query II
SELECT user_name, city_name FROM god_locations WHERE user_name = 'Apollo' ORDER BY city_name;
----
Apollo	Athens
Apollo	Corinth

# Delete from middle table
statement ok
DELETE FROM god_cities WHERE uid = 4 AND city_id = 2;

statement ok
pragma ivm('god_locations');

query I
SELECT count(*) FROM god_locations WHERE user_name = 'Poseidon';
----
0

# ==========================================
# Multi-column JOIN condition
# ==========================================

statement ok
CREATE TABLE orders_j (region VARCHAR, product VARCHAR, qty INT);

statement ok
CREATE TABLE prices (region VARCHAR, product VARCHAR, price DECIMAL(10,2));

statement ok
INSERT INTO prices VALUES ('US', 'A', 10.00), ('US', 'B', 20.00), ('EU', 'A', 12.00);

statement ok
INSERT INTO orders_j VALUES ('US', 'A', 5), ('US', 'B', 3), ('EU', 'A', 10);

statement ok
CREATE MATERIALIZED VIEW order_totals AS
    SELECT o.region, o.product, o.qty, p.price
    FROM orders_j o INNER JOIN prices p ON o.region = p.region AND o.product = p.product;

query IIII
SELECT region, product, qty, price FROM order_totals ORDER BY region, product;
----
EU	A	10	12.00
US	A	5	10.00
US	B	3	20.00

statement ok
INSERT INTO orders_j VALUES ('US', 'A', 2), ('EU', 'A', 7);

statement ok
pragma ivm('order_totals');

query IIII
SELECT region, product, qty, price FROM order_totals ORDER BY region, product, qty;
----
EU	A	7	12.00
EU	A	10	12.00
US	A	2	10.00
US	A	5	10.00
US	B	3	20.00

# Cross-check
query I
SELECT count(*) FROM (
    SELECT o.region, o.product, o.qty, p.price FROM orders_j o INNER JOIN prices p ON o.region = p.region AND o.product = p.product
    EXCEPT ALL
    SELECT * FROM order_totals
);
----
0

# Delete from join
statement ok
DELETE FROM orders_j WHERE region = 'US' AND product = 'A' AND qty = 5;

statement ok
pragma ivm('order_totals');

query IIII
SELECT region, product, qty, price FROM order_totals ORDER BY region, product, qty;
----
EU	A	7	12.00
EU	A	10	12.00
US	A	2	10.00
US	B	3	20.00

# ==========================================
# INSERT and DELETE same row in one batch (net zero delta)
# ==========================================

statement ok
CREATE TABLE jn_left_nz (id INT, val VARCHAR);

statement ok
CREATE TABLE jn_right_nz (id INT, amount INT);

statement ok
INSERT INTO jn_left_nz VALUES (1, 'a'), (2, 'b');

statement ok
INSERT INTO jn_right_nz VALUES (1, 100), (2, 200);

statement ok
CREATE MATERIALIZED VIEW mv_join_nz AS
    SELECT l.val, r.amount FROM jn_left_nz l INNER JOIN jn_right_nz r ON l.id = r.id;

statement ok
PRAGMA ivm('mv_join_nz');

# Cross-check after initial load
query I
SELECT COUNT(*) FROM (
    SELECT l.val, r.amount FROM jn_left_nz l INNER JOIN jn_right_nz r ON l.id = r.id
    EXCEPT ALL
    SELECT * FROM mv_join_nz
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_join_nz
    EXCEPT ALL
    SELECT l.val, r.amount FROM jn_left_nz l INNER JOIN jn_right_nz r ON l.id = r.id
);
----
0

# Insert and delete same row — net zero for the 999 row
statement ok
INSERT INTO jn_right_nz VALUES (1, 999);

statement ok
DELETE FROM jn_right_nz WHERE id = 1 AND amount = 999;

statement ok
PRAGMA ivm('mv_join_nz');

# MV unchanged
query I
SELECT COUNT(*) FROM (
    SELECT l.val, r.amount FROM jn_left_nz l INNER JOIN jn_right_nz r ON l.id = r.id
    EXCEPT ALL
    SELECT * FROM mv_join_nz
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_join_nz
    EXCEPT ALL
    SELECT l.val, r.amount FROM jn_left_nz l INNER JOIN jn_right_nz r ON l.id = r.id
);
----
0

# Insert new row for id=3 (no left match) + delete id=2 from right
statement ok
INSERT INTO jn_right_nz VALUES (3, 300);

statement ok
DELETE FROM jn_right_nz WHERE id = 2;

statement ok
PRAGMA ivm('mv_join_nz');

query I
SELECT COUNT(*) FROM (
    SELECT l.val, r.amount FROM jn_left_nz l INNER JOIN jn_right_nz r ON l.id = r.id
    EXCEPT ALL
    SELECT * FROM mv_join_nz
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_join_nz
    EXCEPT ALL
    SELECT l.val, r.amount FROM jn_left_nz l INNER JOIN jn_right_nz r ON l.id = r.id
);
----
0

# ==========================================
# NULL join keys (should not match in INNER JOIN)
# ==========================================

statement ok
CREATE TABLE jn_left_null (id INT, name VARCHAR);

statement ok
CREATE TABLE jn_right_null (id INT, score INT);

statement ok
INSERT INTO jn_left_null VALUES (1, 'a'), (NULL, 'b'), (3, 'c');

statement ok
INSERT INTO jn_right_null VALUES (1, 10), (NULL, 20), (3, 30);

statement ok
CREATE MATERIALIZED VIEW mv_join_null AS
    SELECT l.name, r.score FROM jn_left_null l INNER JOIN jn_right_null r ON l.id = r.id;

statement ok
PRAGMA ivm('mv_join_null');

# Only (a,10) and (c,30) — NULL != NULL in INNER JOIN
query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM jn_left_null l INNER JOIN jn_right_null r ON l.id = r.id
    EXCEPT ALL
    SELECT * FROM mv_join_null
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_join_null
    EXCEPT ALL
    SELECT l.name, r.score FROM jn_left_null l INNER JOIN jn_right_null r ON l.id = r.id
);
----
0

# Insert another NULL on right — still no NULL matches
statement ok
INSERT INTO jn_right_null VALUES (NULL, 99);

statement ok
PRAGMA ivm('mv_join_null');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM jn_left_null l INNER JOIN jn_right_null r ON l.id = r.id
    EXCEPT ALL
    SELECT * FROM mv_join_null
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_join_null
    EXCEPT ALL
    SELECT l.name, r.score FROM jn_left_null l INNER JOIN jn_right_null r ON l.id = r.id
);
----
0

# Delete NULL row from left — no change to MV
statement ok
DELETE FROM jn_left_null WHERE id IS NULL;

statement ok
PRAGMA ivm('mv_join_null');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM jn_left_null l INNER JOIN jn_right_null r ON l.id = r.id
    EXCEPT ALL
    SELECT * FROM mv_join_null
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_join_null
    EXCEPT ALL
    SELECT l.name, r.score FROM jn_left_null l INNER JOIN jn_right_null r ON l.id = r.id
);
----
0

# ==========================================
# Self-join (same table twice)
# ==========================================

statement ok
CREATE TABLE people (id INT, name VARCHAR, manager_id INT);

statement ok
INSERT INTO people VALUES (1, 'Alice', NULL), (2, 'Bob', 1), (3, 'Charlie', 1), (4, 'Diana', 2);

statement ok
CREATE MATERIALIZED VIEW mv_reports AS
    SELECT e.name AS employee, m.name AS manager
    FROM people e INNER JOIN people m ON e.manager_id = m.id;

query II
SELECT employee, manager FROM mv_reports ORDER BY employee;
----
Bob	Alice
Charlie	Alice
Diana	Bob

# Insert new person who reports to Charlie
statement ok
INSERT INTO people VALUES (5, 'Eve', 3);

statement ok
PRAGMA ivm('mv_reports');

query I
SELECT COUNT(*) FROM (
    SELECT e.name, m.name FROM people e INNER JOIN people m ON e.manager_id = m.id
    EXCEPT ALL SELECT employee, manager FROM mv_reports
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT employee, manager FROM mv_reports
    EXCEPT ALL SELECT e.name, m.name FROM people e INNER JOIN people m ON e.manager_id = m.id
);
----
0

# Delete a manager — cascades to their reports disappearing
statement ok
DELETE FROM people WHERE id = 1;

statement ok
PRAGMA ivm('mv_reports');

query I
SELECT COUNT(*) FROM (
    SELECT e.name, m.name FROM people e INNER JOIN people m ON e.manager_id = m.id
    EXCEPT ALL SELECT employee, manager FROM mv_reports
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT employee, manager FROM mv_reports
    EXCEPT ALL SELECT e.name, m.name FROM people e INNER JOIN people m ON e.manager_id = m.id
);
----
0

# Insert the manager back + a new report simultaneously
statement ok
INSERT INTO people VALUES (1, 'Alice', NULL), (6, 'Frank', 1);

statement ok
PRAGMA ivm('mv_reports');

query I
SELECT COUNT(*) FROM (
    SELECT e.name, m.name FROM people e INNER JOIN people m ON e.manager_id = m.id
    EXCEPT ALL SELECT employee, manager FROM mv_reports
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT employee, manager FROM mv_reports
    EXCEPT ALL SELECT e.name, m.name FROM people e INNER JOIN people m ON e.manager_id = m.id
);
----
0

# ==========================================
# 4-table join
# ==========================================

statement ok
CREATE TABLE t4_products (pid INT, pname VARCHAR);

statement ok
CREATE TABLE t4_warehouses (wid INT, wname VARCHAR);

statement ok
CREATE TABLE t4_inventory (pid INT, wid INT, qty INT);

statement ok
CREATE TABLE t4_suppliers (sid INT, pid INT, sname VARCHAR);

statement ok
INSERT INTO t4_products VALUES (1, 'Widget'), (2, 'Gadget');

statement ok
INSERT INTO t4_warehouses VALUES (10, 'East'), (20, 'West');

statement ok
INSERT INTO t4_inventory VALUES (1, 10, 100), (2, 20, 50);

statement ok
INSERT INTO t4_suppliers VALUES (100, 1, 'Acme'), (200, 2, 'Globex');

statement ok
CREATE MATERIALIZED VIEW mv_4way AS
    SELECT p.pname, w.wname, i.qty, s.sname
    FROM t4_products p
    INNER JOIN t4_inventory i ON i.pid = p.pid
    INNER JOIN t4_warehouses w ON w.wid = i.wid
    INNER JOIN t4_suppliers s ON s.pid = p.pid;

query IIII
SELECT pname, wname, qty, sname FROM mv_4way ORDER BY pname, wname;
----
Gadget	West	50	Globex
Widget	East	100	Acme

# Add new inventory row linking existing product+warehouse
statement ok
INSERT INTO t4_inventory VALUES (1, 20, 30);

statement ok
PRAGMA ivm('mv_4way');

query I
SELECT COUNT(*) FROM (
    SELECT p.pname, w.wname, i.qty, s.sname FROM t4_products p
    INNER JOIN t4_inventory i ON i.pid = p.pid INNER JOIN t4_warehouses w ON w.wid = i.wid
    INNER JOIN t4_suppliers s ON s.pid = p.pid
    EXCEPT ALL SELECT * FROM mv_4way
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_4way
    EXCEPT ALL SELECT p.pname, w.wname, i.qty, s.sname FROM t4_products p
    INNER JOIN t4_inventory i ON i.pid = p.pid INNER JOIN t4_warehouses w ON w.wid = i.wid
    INNER JOIN t4_suppliers s ON s.pid = p.pid
);
----
0

# Insert new product + supplier + inventory all at once
statement ok
INSERT INTO t4_products VALUES (3, 'Doohickey');

statement ok
INSERT INTO t4_suppliers VALUES (300, 3, 'Initech');

statement ok
INSERT INTO t4_inventory VALUES (3, 10, 75);

statement ok

# ==========================================
# DATE columns as GROUP BY keys
# ==========================================

statement ok
CREATE TABLE daily_sales (sale_date DATE, amount INT);

statement ok
INSERT INTO daily_sales VALUES ('2024-01-01', 100), ('2024-01-01', 200), ('2024-01-02', 300);

statement ok
CREATE MATERIALIZED VIEW mv_daily AS SELECT sale_date, SUM(amount) AS total FROM daily_sales GROUP BY sale_date;

query II
SELECT sale_date, total FROM mv_daily ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	300

statement ok
INSERT INTO daily_sales VALUES ('2024-01-02', 50), ('2024-01-03', 400);

statement ok
pragma ivm('mv_daily');

query II
SELECT sale_date, total FROM mv_daily ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	350
2024-01-03	400

# Cross-check
query II
SELECT sale_date, SUM(amount) FROM daily_sales GROUP BY sale_date ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	350
2024-01-03	400

# ==========================================
# Empty table → CREATE MV → INSERT → refresh
# ==========================================

statement ok
CREATE TABLE empty_base (id INT, val INT);

statement ok
CREATE MATERIALIZED VIEW mv_empty AS SELECT id, SUM(val) AS total FROM empty_base GROUP BY id;

query II
SELECT id, total FROM mv_empty;
----

statement ok
INSERT INTO empty_base VALUES (1, 100), (2, 200);

statement ok
pragma ivm('mv_empty');

query II
SELECT id, total FROM mv_empty ORDER BY id;
----
1	100
2	200

# ==========================================
# Large batch INSERT (1000 rows)
# ==========================================

statement ok
CREATE TABLE batch_tbl (grp INT, val INT);

statement ok
CREATE MATERIALIZED VIEW mv_batch AS SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM batch_tbl GROUP BY grp;

statement ok
INSERT INTO batch_tbl SELECT i % 10, i FROM range(1000) t(i);

statement ok
pragma ivm('mv_batch');

# Cross-check
query I
SELECT COUNT(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM batch_tbl GROUP BY grp
    EXCEPT
    SELECT grp, total, cnt FROM mv_batch
);
----
0

# ==========================================
# DELETE all rows → MV should be empty
# ==========================================

statement ok
CREATE TABLE del_all (grp VARCHAR, val INT);

statement ok
INSERT INTO del_all VALUES ('a', 1), ('b', 2);

statement ok
CREATE MATERIALIZED VIEW mv_del_all AS SELECT grp, SUM(val) AS total FROM del_all GROUP BY grp;

statement ok
DELETE FROM del_all;

statement ok
pragma ivm('mv_del_all');

query II
SELECT grp, total FROM mv_del_all;
----

# ==========================================
# UNGROUPED (SCALAR) AGGREGATES
# ==========================================


statement ok
CREATE TABLE scores (id INT, value INT, label VARCHAR);

statement ok
INSERT INTO scores VALUES (1, 10, 'a'), (2, 20, 'b'), (3, 30, 'c');

statement ok
create materialized view score_totals as (select sum(value) as total, count(label) as cnt from scores);

query II
SELECT total, cnt FROM score_totals;
----
60	3

# --- Insert ---
statement ok
INSERT INTO scores VALUES (4, 40, 'd');

statement ok
pragma ivm('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
100	4

# --- Delete ---
statement ok
DELETE FROM scores WHERE id = 1;

statement ok
pragma ivm('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
90	3

# --- Mixed insert + delete ---
statement ok
INSERT INTO scores VALUES (5, 50, 'e');

statement ok
DELETE FROM scores WHERE id = 2;

statement ok
pragma ivm('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
120	3

# --- No-op PRAGMA ---
statement ok
pragma ivm('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
120	3

# --- Batch insert ---
statement ok
INSERT INTO scores VALUES (6, 10, 'f'), (7, 20, 'g'), (8, 30, 'h');

statement ok
pragma ivm('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
180	6

# --- Delete multiple rows at once ---
statement ok
DELETE FROM scores WHERE value <= 20;

statement ok
pragma ivm('score_totals');

# Remaining: id=3(30), id=4(40), id=5(50), id=8(30) = 150, cnt=4
query II
SELECT total, cnt FROM score_totals;
----
150	4


# ==========================================
# MIN / MAX AGGREGATES
# ==========================================

# Test 1: MIN with GROUP BY

statement ok
CREATE TABLE t1 (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t1 VALUES (1, 'a', 10), (2, 'a', 20), (3, 'b', 30), (4, 'b', 5);

statement ok
CREATE MATERIALIZED VIEW mv_min AS SELECT grp, MIN(val) AS min_val FROM t1 GROUP BY grp;

statement ok
INSERT INTO t1 VALUES (5, 'a', 3);

statement ok
PRAGMA ivm('mv_min');

query II
SELECT grp, min_val FROM mv_min ORDER BY grp;
----
a	3
b	5

statement ok
DELETE FROM t1 WHERE id = 5;

statement ok
PRAGMA ivm('mv_min');

query II
SELECT grp, min_val FROM mv_min ORDER BY grp;
----
a	10
b	5

# Test 2: MAX with GROUP BY

statement ok
CREATE TABLE t2 (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t2 VALUES (1, 'x', 100), (2, 'x', 200), (3, 'y', 50), (4, 'y', 75);

statement ok
CREATE MATERIALIZED VIEW mv_max AS SELECT grp, MAX(val) AS max_val FROM t2 GROUP BY grp;

statement ok
INSERT INTO t2 VALUES (5, 'y', 300);

statement ok
PRAGMA ivm('mv_max');

query II
SELECT grp, max_val FROM mv_max ORDER BY grp;
----
x	200
y	300

statement ok
DELETE FROM t2 WHERE id = 5;

statement ok
PRAGMA ivm('mv_max');

query II
SELECT grp, max_val FROM mv_max ORDER BY grp;
----
x	200
y	75

# Test 3: Mixed aggregates (SUM + MIN + MAX)

statement ok
CREATE TABLE t3 (id INT, grp VARCHAR, a INT, b INT, c INT);

statement ok
INSERT INTO t3 VALUES (1, 'g1', 10, 100, 1), (2, 'g1', 20, 200, 2), (3, 'g2', 30, 300, 3);

statement ok
CREATE MATERIALIZED VIEW mv_mixed AS SELECT grp, SUM(a) AS sum_a, MIN(b) AS min_b, MAX(c) AS max_c FROM t3 GROUP BY grp;

statement ok
INSERT INTO t3 VALUES (4, 'g1', 5, 50, 10);

statement ok
PRAGMA ivm('mv_mixed');

query IIII
SELECT grp, sum_a, min_b, max_c FROM mv_mixed ORDER BY grp;
----
g1	35	50	10
g2	30	300	3

statement ok
DELETE FROM t3 WHERE id = 4;

statement ok
PRAGMA ivm('mv_mixed');

query IIII
SELECT grp, sum_a, min_b, max_c FROM mv_mixed ORDER BY grp;
----
g1	30	100	2
g2	30	300	3

# Test 5: Ungrouped MIN aggregate

statement ok
CREATE TABLE t5 (id INT, val INT);

statement ok
INSERT INTO t5 VALUES (1, 100), (2, 50), (3, 200);

statement ok
CREATE MATERIALIZED VIEW mv_simple_min AS SELECT MIN(val) AS min_val FROM t5;

statement ok
INSERT INTO t5 VALUES (4, 10);

statement ok
PRAGMA ivm('mv_simple_min');

query I
SELECT min_val FROM mv_simple_min;
----
10

statement ok
DELETE FROM t5 WHERE id = 4;

statement ok
PRAGMA ivm('mv_simple_min');

query I
SELECT min_val FROM mv_simple_min;
----
50

# Test 6: MIN/MAX with JOIN + GROUP BY

statement ok
CREATE TABLE departments (dept_id INT, dept_name VARCHAR);

statement ok
INSERT INTO departments VALUES (1, 'engineering'), (2, 'sales');

statement ok
CREATE TABLE employees (id INT, dept_id INT, salary INT);

statement ok
INSERT INTO employees VALUES (1, 1, 100), (2, 1, 200), (3, 2, 150), (4, 2, 300);

statement ok
CREATE MATERIALIZED VIEW mv_dept_salaries AS
    SELECT d.dept_name, MIN(e.salary) AS min_salary, MAX(e.salary) AS max_salary
    FROM departments d INNER JOIN employees e ON e.dept_id = d.dept_id
    GROUP BY d.dept_name;

statement ok
INSERT INTO employees VALUES (5, 1, 50);

statement ok
PRAGMA ivm('mv_dept_salaries');

query III
SELECT dept_name, min_salary, max_salary FROM mv_dept_salaries ORDER BY dept_name;
----
engineering	50	200
sales	150	300

statement ok
DELETE FROM employees WHERE id = 5;

statement ok
PRAGMA ivm('mv_dept_salaries');

query III
SELECT dept_name, min_salary, max_salary FROM mv_dept_salaries ORDER BY dept_name;
----
engineering	100	200
sales	150	300

statement ok
INSERT INTO departments VALUES (3, 'marketing');

statement ok
INSERT INTO employees VALUES (6, 3, 75);

statement ok
PRAGMA ivm('mv_dept_salaries');

query III
SELECT dept_name, min_salary, max_salary FROM mv_dept_salaries ORDER BY dept_name;
----
engineering	100	200
marketing	75	75
sales	150	300

# ==========================================
# AVG aggregate (group-recompute strategy)
# ==========================================

statement ok
CREATE TABLE avg_data (grp VARCHAR, val DOUBLE);

statement ok
INSERT INTO avg_data VALUES ('a', 10), ('a', 20), ('b', 30);

statement ok
CREATE MATERIALIZED VIEW mv_avg AS SELECT grp, AVG(val) AS avg_val FROM avg_data GROUP BY grp;

query II
SELECT grp, avg_val FROM mv_avg ORDER BY grp;
----
a	15.0
b	30.0

statement ok
INSERT INTO avg_data VALUES ('a', 40), ('c', 100);

statement ok
pragma ivm('mv_avg');

query II
SELECT grp, avg_val FROM mv_avg ORDER BY grp;
----
a	23.333333333333332
b	30.0
c	100.0

# Cross-check
query II
SELECT grp, AVG(val) FROM avg_data GROUP BY grp ORDER BY grp;
----
a	23.333333333333332
b	30.0
c	100.0

# Delete from group
statement ok
DELETE FROM avg_data WHERE grp = 'a' AND val = 10;

statement ok
pragma ivm('mv_avg');

query II
SELECT grp, avg_val FROM mv_avg ORDER BY grp;
----
a	30.0
b	30.0
c	100.0

# Ungrouped AVG
statement ok
CREATE TABLE avg_ungrouped (val INT);

statement ok
INSERT INTO avg_ungrouped VALUES (10), (20), (30);

statement ok
CREATE MATERIALIZED VIEW mv_avg_scalar AS SELECT AVG(val) AS avg_val FROM avg_ungrouped;

query I
SELECT avg_val FROM mv_avg_scalar;
----
20.0

statement ok
INSERT INTO avg_ungrouped VALUES (40);

statement ok
pragma ivm('mv_avg_scalar');

query I
SELECT avg_val FROM mv_avg_scalar;
----
25.0

# Cross-check
query I
SELECT AVG(val) FROM avg_ungrouped;
----
25.0

# ==========================================
# HAVING clause (optimized to FILTER above AGGREGATE by DuckDB)
# ==========================================

statement ok
CREATE TABLE having_test (region VARCHAR, amount INT);

statement ok
INSERT INTO having_test VALUES ('a', 100), ('a', 200), ('b', 50), ('c', 10);

statement ok
CREATE MATERIALIZED VIEW mv_having AS SELECT region, SUM(amount) AS total FROM having_test GROUP BY region HAVING SUM(amount) > 60;

query II
SELECT region, total FROM mv_having ORDER BY region;
----
a	300

statement ok
INSERT INTO having_test VALUES ('b', 100), ('c', 200);

statement ok
PRAGMA ivm('mv_having');

# Cross-check
query I
SELECT COUNT(*) FROM (
    SELECT region, SUM(amount) AS total FROM having_test GROUP BY region HAVING SUM(amount) > 60
    EXCEPT ALL
    SELECT region, total FROM mv_having
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT region, total FROM mv_having
    EXCEPT ALL
    SELECT region, SUM(amount) AS total FROM having_test GROUP BY region HAVING SUM(amount) > 60
);
----
0

# ==========================================
# CASE WHEN in aggregates
# ==========================================

statement ok
CREATE TABLE case_test (category VARCHAR, value INT);

statement ok
INSERT INTO case_test VALUES ('a', 10), ('a', -5), ('b', 20), ('b', -3);

statement ok
CREATE MATERIALIZED VIEW mv_case AS SELECT category, SUM(CASE WHEN value > 0 THEN value ELSE 0 END) AS pos_sum FROM case_test GROUP BY category;

query II
SELECT category, pos_sum FROM mv_case ORDER BY category;
----
a	10
b	20

statement ok
INSERT INTO case_test VALUES ('a', 30), ('b', -100), ('c', 50);

statement ok
PRAGMA ivm('mv_case');

# Cross-check
query I
SELECT COUNT(*) FROM (
    SELECT category, SUM(CASE WHEN value > 0 THEN value ELSE 0 END) AS pos_sum FROM case_test GROUP BY category
    EXCEPT ALL
    SELECT category, pos_sum FROM mv_case
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT category, pos_sum FROM mv_case
    EXCEPT ALL
    SELECT category, SUM(CASE WHEN value > 0 THEN value ELSE 0 END) AS pos_sum FROM case_test GROUP BY category
);
----
0

# ==========================================
# NULL values in aggregate columns with edge case deletions
# ==========================================

statement ok
CREATE TABLE agg_null_edge (grp VARCHAR, val INT);

statement ok
INSERT INTO agg_null_edge VALUES ('a', 10), ('a', NULL), ('b', NULL), ('b', NULL), ('c', 30);

statement ok
CREATE MATERIALIZED VIEW mv_agg_null_edge AS
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val
    FROM agg_null_edge GROUP BY grp;

statement ok
PRAGMA ivm('mv_agg_null_edge');

# Cross-check after initial load
query I
SELECT COUNT(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val FROM agg_null_edge GROUP BY grp
    EXCEPT ALL
    SELECT grp, total, cnt, cnt_val FROM mv_agg_null_edge
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, total, cnt, cnt_val FROM mv_agg_null_edge
    EXCEPT ALL
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val FROM agg_null_edge GROUP BY grp
);
----
0

# Delete all NULL vals — group 'b' loses all rows (cnt becomes 0 → group removed)
statement ok
DELETE FROM agg_null_edge WHERE val IS NULL;

statement ok
PRAGMA ivm('mv_agg_null_edge');

query I
SELECT COUNT(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val FROM agg_null_edge GROUP BY grp
    EXCEPT ALL
    SELECT grp, total, cnt, cnt_val FROM mv_agg_null_edge
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, total, cnt, cnt_val FROM mv_agg_null_edge
    EXCEPT ALL
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val FROM agg_null_edge GROUP BY grp
);
----
0

# Insert only NULLs into 'a': SUM unchanged, COUNT(*) increases, COUNT(val) unchanged
statement ok
INSERT INTO agg_null_edge VALUES ('a', NULL), ('a', NULL);

statement ok
PRAGMA ivm('mv_agg_null_edge');

query I
SELECT COUNT(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val FROM agg_null_edge GROUP BY grp
    EXCEPT ALL
    SELECT grp, total, cnt, cnt_val FROM mv_agg_null_edge
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, total, cnt, cnt_val FROM mv_agg_null_edge
    EXCEPT ALL
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val FROM agg_null_edge GROUP BY grp
);
----
0

# ==========================================
# UPDATE that changes GROUP BY key (row moves between groups)
# ==========================================

statement ok
CREATE TABLE agg_grp_move (grp VARCHAR, val INT);

statement ok

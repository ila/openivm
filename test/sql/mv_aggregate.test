statement ok
CREATE TABLE agg_vanish (grp VARCHAR, val INT);

statement ok
INSERT INTO agg_vanish VALUES ('p', 10), ('q', 20), ('r', 30);

statement ok
CREATE MATERIALIZED VIEW mv_agg_vanish AS
    SELECT grp, SUM(val) AS total FROM agg_vanish GROUP BY grp;

statement ok

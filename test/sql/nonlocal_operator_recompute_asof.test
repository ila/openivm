    )
    SELECT
        m1.symbol AS symbol,
        COUNT(*) AS pair_count,
        SUM(m2.price) AS total_peer_price
    FROM matched m1
    JOIN matched m2 ON m1.symbol = m2.symbol
    GROUP BY m1.symbol
    EXCEPT ALL
    SELECT symbol, pair_count, total_peer_price FROM mv_oprec_cte_asof

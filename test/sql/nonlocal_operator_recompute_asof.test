# ==========================================
# Hidden non-local operators inside materialized CTEs are still classified conservatively
# ==========================================

statement ok
CREATE TABLE oprec_cte_asof_trades (symbol VARCHAR, ts TIMESTAMP, qty INT);

statement ok
CREATE TABLE oprec_cte_asof_prices (symbol VARCHAR, ts TIMESTAMP, price INT);

statement ok
INSERT INTO oprec_cte_asof_trades VALUES
    ('A', TIMESTAMP '2024-03-01 10:00:00', 1),
    ('A', TIMESTAMP '2024-03-01 10:10:00', 2),
    ('B', TIMESTAMP '2024-03-01 10:05:00', 3);

statement ok
INSERT INTO oprec_cte_asof_prices VALUES
    ('A', TIMESTAMP '2024-03-01 09:55:00', 100),
    ('A', TIMESTAMP '2024-03-01 10:08:00', 180),
    ('B', TIMESTAMP '2024-03-01 10:00:00', 120);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_cte_asof AS
    WITH matched AS MATERIALIZED (
        SELECT
            t.symbol AS symbol,
            t.ts AS trade_ts,
            p.price AS price
        FROM oprec_cte_asof_trades t
        ASOF JOIN oprec_cte_asof_prices p
          ON t.symbol = p.symbol
         AND t.ts >= p.ts
    )
    SELECT
        m1.symbol AS symbol,
        COUNT(*) AS pair_count,
        SUM(m2.price) AS total_peer_price
    FROM matched m1
    JOIN matched m2 ON m1.symbol = m2.symbol
    GROUP BY m1.symbol;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_cte_asof';
----
6

query T
SELECT group_recompute_affected_mode FROM openivm_views WHERE view_name = 'mv_oprec_cte_asof';
----
current_diff


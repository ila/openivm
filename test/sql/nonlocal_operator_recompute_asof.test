# ==========================================
# ASOF under a partitioned window stays partition-recompute
# ==========================================

statement ok
CREATE TABLE oprec_asof_win_trades (symbol VARCHAR, ts TIMESTAMP, qty INT);

statement ok
CREATE TABLE oprec_asof_win_prices (symbol VARCHAR, ts TIMESTAMP, price INT);

statement ok
INSERT INTO oprec_asof_win_trades VALUES
    ('A', TIMESTAMP '2024-02-01 10:00:00', 1),
    ('A', TIMESTAMP '2024-02-01 10:20:00', 2),
    ('B', TIMESTAMP '2024-02-01 10:15:00', 3),
    ('C', TIMESTAMP '2024-02-01 10:10:00', 4);

statement ok
INSERT INTO oprec_asof_win_prices VALUES
    ('A', TIMESTAMP '2024-02-01 09:00:00', 100),
    ('A', TIMESTAMP '2024-02-01 10:18:00', 180),
    ('B', TIMESTAMP '2024-02-01 10:12:00', 120),
    ('C', TIMESTAMP '2024-02-01 10:00:00', 130);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_asof_window AS
    SELECT
        symbol,
        trade_ts,
        qty,
        price_ts,
        price,
        row_number() OVER (PARTITION BY symbol ORDER BY trade_ts, price_ts) AS rn
    FROM (
        SELECT
            t.symbol AS symbol,
            t.ts AS trade_ts,
            t.qty AS qty,
            p.ts AS price_ts,
            p.price AS price
        FROM oprec_asof_win_trades t
        ASOF JOIN oprec_asof_win_prices p
          ON t.symbol = p.symbol
         AND t.ts >= p.ts
    ) q;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_asof_window';
----
5

statement ok
INSERT INTO oprec_asof_win_prices VALUES ('A', TIMESTAMP '2024-02-01 10:19:00', 190);

statement ok
DELETE FROM oprec_asof_win_trades WHERE symbol = 'C';

statement ok
UPDATE oprec_asof_win_trades SET qty = 7 WHERE symbol = 'B';

statement ok
PRAGMA refresh('mv_oprec_asof_window');

query I
SELECT count(*) FROM (
    SELECT
        symbol,
        trade_ts,
        qty,
        price_ts,
        price,
        row_number() OVER (PARTITION BY symbol ORDER BY trade_ts, price_ts) AS rn
    FROM (
        SELECT
            t.symbol AS symbol,
            t.ts AS trade_ts,
            t.qty AS qty,
            p.ts AS price_ts,
            p.price AS price
        FROM oprec_asof_win_trades t
        ASOF JOIN oprec_asof_win_prices p
          ON t.symbol = p.symbol
         AND t.ts >= p.ts
    ) q
    EXCEPT ALL
    SELECT symbol, trade_ts, qty, price_ts, price, rn FROM mv_oprec_asof_window
);
----
0

query I
SELECT count(*) FROM (
    SELECT symbol, trade_ts, qty, price_ts, price, rn FROM mv_oprec_asof_window
    EXCEPT ALL
    SELECT
        symbol,
        trade_ts,
        qty,
        price_ts,
        price,
        row_number() OVER (PARTITION BY symbol ORDER BY trade_ts, price_ts) AS rn
    FROM (
        SELECT
            t.symbol AS symbol,
            t.ts AS trade_ts,
            t.qty AS qty,
            p.ts AS price_ts,
            p.price AS price
        FROM oprec_asof_win_trades t
        ASOF JOIN oprec_asof_win_prices p
          ON t.symbol = p.symbol
         AND t.ts >= p.ts

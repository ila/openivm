# name: test/sql/ducklake_cte.test
# description: Test LPTS CTE generation for DuckLake MVs — no AT VERSION, correct catalog refs
# group: [sql]

require openivm

require parquet

statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH '__TEST_DIR__/ducklake_cte.db' AS dl (TYPE ducklake);

# ==========================================
# MV definition should NOT contain AT VERSION
# ==========================================

statement ok
CREATE TABLE dl.products (id INTEGER, name VARCHAR, price DECIMAL(10,2));

statement ok
INSERT INTO dl.products VALUES (1, 'Widget', 9.99), (2, 'Gadget', 19.99);

statement ok
CREATE MATERIALIZED VIEW dl.mv_prices AS
  SELECT name, SUM(price) as total, COUNT(*) as cnt FROM dl.products GROUP BY name;

# The stored view query should reference dl.main.products without AT VERSION
query I
SELECT sql_string LIKE '%dl.main.products%' FROM openivm_views WHERE view_name = 'mv_prices';
----
true

query I
SELECT sql_string NOT LIKE '%AT (VERSION%' FROM openivm_views WHERE view_name = 'mv_prices';
----
true

# ==========================================
# Verify incremental refresh produces correct results
# (tests that the CTE SQL round-trips correctly)
# ==========================================

statement ok
INSERT INTO dl.products VALUES (3, 'Widget', 5.00);

statement ok
PRAGMA refresh('mv_prices');

# EXCEPT ALL
query I
SELECT count(*) FROM (
  SELECT name, total, cnt FROM dl.mv_prices
  EXCEPT ALL
  SELECT name, SUM(price), COUNT(*) FROM dl.products GROUP BY name
);
----
0

query I
SELECT count(*) FROM (
  SELECT name, SUM(price), COUNT(*) FROM dl.products GROUP BY name
  EXCEPT ALL
  SELECT name, total, cnt FROM dl.mv_prices
);
----
0

# ==========================================
# Combined operators: filter + aggregate over DuckLake
# ==========================================

statement ok
CREATE TABLE dl.orders (id INTEGER, region VARCHAR, amount INTEGER, status VARCHAR);

statement ok
INSERT INTO dl.orders VALUES (1, 'east', 100, 'active'), (2, 'west', 200, 'active'), (3, 'east', 150, 'cancelled');

statement ok
CREATE MATERIALIZED VIEW dl.mv_active AS
  SELECT region, SUM(amount) as total, COUNT(*) as cnt
  FROM dl.orders WHERE status = 'active' GROUP BY region;

query III rowsort
SELECT * FROM dl.mv_active ORDER BY region;
----
east	100	1
west	200	1

statement ok
INSERT INTO dl.orders VALUES (4, 'east', 50, 'active'), (5, 'west', 75, 'cancelled');

statement ok
PRAGMA refresh('mv_active');

# EXCEPT ALL
query I
SELECT count(*) FROM (
  SELECT region, total, cnt FROM dl.mv_active
  EXCEPT ALL
  SELECT region, SUM(amount), COUNT(*) FROM dl.orders WHERE status = 'active' GROUP BY region
);
----
0

query I
SELECT count(*) FROM (
  SELECT region, SUM(amount), COUNT(*) FROM dl.orders WHERE status = 'active' GROUP BY region
  EXCEPT ALL
  SELECT region, total, cnt FROM dl.mv_active
);
----
0

# ==========================================
# Repeated aggregate CTE under join
# ==========================================

statement ok
CREATE TABLE dl.cte_reuse (a INTEGER, b INTEGER);

statement ok
INSERT INTO dl.cte_reuse VALUES (1, 10), (1, 20), (2, 5);

statement ok
CREATE MATERIALIZED VIEW dl.mv_cte_reuse AS
  WITH s AS (
    SELECT a, SUM(b) AS sb
    FROM dl.cte_reuse
    GROUP BY a
  )
  SELECT s.a, s.sb, g.av
  FROM s
  CROSS JOIN (SELECT AVG(sb) AS av FROM s) g;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_cte_reuse';
----
6

query I
SELECT group_columns FROM openivm_views WHERE view_name = 'mv_cte_reuse';
----
a

statement ok
INSERT INTO dl.cte_reuse VALUES (2, 15);

statement ok
PRAGMA refresh('mv_cte_reuse');

query I
SELECT count(*) FROM (
  SELECT a, sb, av FROM dl.mv_cte_reuse
  EXCEPT ALL
  SELECT * FROM (
    WITH s AS (
      SELECT a, SUM(b) AS sb
      FROM dl.cte_reuse
      GROUP BY a
    )
    SELECT s.a, s.sb, g.av
    FROM s
    CROSS JOIN (SELECT AVG(sb) AS av FROM s) g
  ) expected
);
----
0

query I
SELECT count(*) FROM (
  SELECT * FROM (
    WITH s AS (
      SELECT a, SUM(b) AS sb
      FROM dl.cte_reuse
      GROUP BY a
    )
    SELECT s.a, s.sb, g.av
    FROM s
    CROSS JOIN (SELECT AVG(sb) AS av FROM s) g
  ) expected
  EXCEPT ALL
  SELECT a, sb, av FROM dl.mv_cte_reuse
);
----
0

# ==========================================
# Join over aggregate CTE without visible aggregate keys
# ==========================================

statement ok
CREATE TABLE dl.joa_customer (w INTEGER, d INTEGER, c INTEGER, discount DOUBLE);

statement ok
CREATE TABLE dl.joa_orderline (w INTEGER, d INTEGER, o INTEGER, amount DOUBLE);

statement ok
INSERT INTO dl.joa_customer VALUES (1, 10, 100, 0.10), (1, 10, 101, 0.20), (2, 20, 200, 0.00);

statement ok
INSERT INTO dl.joa_orderline VALUES (1, 10, 500, 30.0), (1, 10, 500, 20.0), (2, 20, 700, 15.0);

statement ok
CREATE MATERIALIZED VIEW dl.mv_join_over_agg_hidden_key AS
  WITH grand_total AS (
    SELECT SUM(amount) AS amt
    FROM dl.joa_orderline
  )
  SELECT c.w AS w, c.c AS c, grand_total.amt AS total_amt
  FROM dl.joa_customer c
  CROSS JOIN grand_total;

query II
SELECT type, group_recompute_affected_mode FROM openivm_views WHERE view_name = 'mv_join_over_agg_hidden_key';
----
6	current_diff

statement ok
INSERT INTO dl.joa_orderline VALUES (1, 10, 501, 40.0);

statement ok
DELETE FROM dl.joa_orderline WHERE w = 1 AND d = 10 AND o = 500 AND amount = 20.0;

statement ok
INSERT INTO dl.joa_customer VALUES (2, 20, 201, 0.50);

statement ok
PRAGMA refresh('mv_join_over_agg_hidden_key');

query I
SELECT count(*) FROM (
  SELECT w, c, total_amt FROM dl.mv_join_over_agg_hidden_key
  EXCEPT ALL
  SELECT * FROM (
    WITH grand_total AS (
      SELECT SUM(amount) AS amt
      FROM dl.joa_orderline
    )
    SELECT c.w AS w, c.c AS c, grand_total.amt AS total_amt
    FROM dl.joa_customer c
    CROSS JOIN grand_total
  ) expected
);
----
0

query I
SELECT count(*) FROM (
  SELECT * FROM (
    WITH grand_total AS (
      SELECT SUM(amount) AS amt
      FROM dl.joa_orderline
    )
    SELECT c.w AS w, c.c AS c, grand_total.amt AS total_amt
    FROM dl.joa_customer c
    CROSS JOIN grand_total
  ) expected
  EXCEPT ALL
  SELECT w, c, total_amt FROM dl.mv_join_over_agg_hidden_key
);
----
0

# ==========================================
# COUNT DISTINCT join aggregate with projected group key
# ==========================================

statement ok
CREATE TABLE dl.joa_district (w INTEGER, d INTEGER);

statement ok
INSERT INTO dl.joa_district VALUES (1, 10), (2, 20);

statement ok
CREATE MATERIALIZED VIEW dl.mv_count_distinct_projected_key AS
  SELECT COALESCE(c.w, -1) AS w,
         COUNT(DISTINCT c.d) AS districts_count,
         SUM(c.c) AS customer_sum
  FROM dl.joa_customer c
  JOIN dl.joa_district d ON c.w = d.w AND c.d = d.d
  GROUP BY c.w;

query II
SELECT type, group_recompute_affected_mode FROM openivm_views WHERE view_name = 'mv_count_distinct_projected_key';
----
6	current_diff

statement ok
INSERT INTO dl.joa_district VALUES (3, 30);

statement ok
INSERT INTO dl.joa_customer VALUES (3, 30, 300, 0.25), (3, 30, 301, 0.30);

statement ok
DELETE FROM dl.joa_customer WHERE w = 1 AND d = 10 AND c = 101;

statement ok
PRAGMA refresh('mv_count_distinct_projected_key');

query I
SELECT count(*) FROM (
  SELECT w, districts_count, customer_sum FROM dl.mv_count_distinct_projected_key
  EXCEPT ALL
  SELECT COALESCE(c.w, -1) AS w,
         COUNT(DISTINCT c.d) AS districts_count,
         SUM(c.c) AS customer_sum
  FROM dl.joa_customer c
  JOIN dl.joa_district d ON c.w = d.w AND c.d = d.d
  GROUP BY c.w
);
----
0

query I
SELECT count(*) FROM (
  SELECT COALESCE(c.w, -1) AS w,
         COUNT(DISTINCT c.d) AS districts_count,
         SUM(c.c) AS customer_sum
  FROM dl.joa_customer c
  JOIN dl.joa_district d ON c.w = d.w AND c.d = d.d
  GROUP BY c.w
  EXCEPT ALL
  SELECT w, districts_count, customer_sum FROM dl.mv_count_distinct_projected_key
);
----
0

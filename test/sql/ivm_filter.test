# name: test/sql/ivm_filter.test
# description: Test IVM with filters
# group: [sql]

require openivm

statement ok
CREATE TABLE products (id INT, name VARCHAR, price INT, category VARCHAR);

statement ok
INSERT INTO products VALUES (1, 'Widget', 10, 'A'), (2, 'Gadget', 25, 'B'), (3, 'Doohickey', 5, 'A');

statement ok
create materialized view cheap_products as (select id, name, price from products where price < 20);

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
1	Widget	10
3	Doohickey	5

# --- Insert: matching filter ---
statement ok
INSERT INTO products VALUES (4, 'Thingamajig', 8, 'A');

statement ok
pragma ivm('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
1	Widget	10
3	Doohickey	5
4	Thingamajig	8

# --- Insert: NOT matching filter (price >= 20) ---
statement ok
INSERT INTO products VALUES (5, 'Expensive', 50, 'B');

statement ok
pragma ivm('cheap_products');

# MV unchanged (filtered out)
query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
1	Widget	10
3	Doohickey	5
4	Thingamajig	8

# --- Delete: row that was in the view ---
statement ok
DELETE FROM products WHERE id = 1;

statement ok
pragma ivm('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8

# --- No-op PRAGMA ---
statement ok
pragma ivm('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8

# --- Insert at the boundary (price = 19, just under filter) ---
statement ok
INSERT INTO products VALUES (6, 'Boundary', 19, 'C');

statement ok
pragma ivm('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8
6	Boundary	19

# --- Insert at the boundary (price = 20, NOT matching filter) ---
statement ok
INSERT INTO products VALUES (7, 'TooExpensive', 20, 'C');

statement ok
pragma ivm('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8
6	Boundary	19

# --- Mixed insert + delete ---
statement ok
INSERT INTO products VALUES (8, 'Cheap', 1, 'A');

statement ok
DELETE FROM products WHERE id = 3;

statement ok
pragma ivm('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
4	Thingamajig	8
6	Boundary	19
8	Cheap	1

# --- Delete row not in MV (should be no-op for MV) ---
statement ok
DELETE FROM products WHERE id = 5;

statement ok
pragma ivm('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
4	Thingamajig	8
6	Boundary	19
8	Cheap	1

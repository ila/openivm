# name: test/sql/ivm_filter.test
# description: Test IVM with filters
# group: [sql]

require openivm

statement ok
CREATE TABLE IF NOT EXISTS _duckdb_ivm_views (view_name VARCHAR PRIMARY KEY, sql_string VARCHAR, type TINYINT, last_update TIMESTAMP);

statement ok
CREATE TABLE IF NOT EXISTS _duckdb_ivm_delta_tables (view_name VARCHAR, table_name VARCHAR, last_update TIMESTAMP, PRIMARY KEY(view_name, table_name));

# --- Base table ---
statement ok
CREATE TABLE products (id INT, name VARCHAR, price INT, category VARCHAR);

statement ok
INSERT INTO products VALUES (1, 'Widget', 10, 'A'), (2, 'Gadget', 25, 'B'), (3, 'Doohickey', 5, 'A');

# --- Materialized view: projection with filter ---
statement ok
CREATE TABLE cheap_products AS SELECT id, name, price FROM products WHERE price < 20;

statement ok
CREATE TABLE delta_cheap_products AS SELECT *, true AS _duckdb_ivm_multiplicity FROM cheap_products LIMIT 0;

statement ok
CREATE TABLE delta_products AS SELECT *, true AS _duckdb_ivm_multiplicity, now()::timestamp AS _duckdb_ivm_timestamp FROM products LIMIT 0;

statement ok
INSERT INTO _duckdb_ivm_views VALUES ('cheap_products', 'select id, name, price from products where price < 20', 2, now()::timestamp);

statement ok
INSERT INTO _duckdb_ivm_delta_tables VALUES ('cheap_products', 'delta_products', '1970-01-01');

# --- Insert: matching filter ---
statement ok
INSERT INTO products VALUES (4, 'Thingamajig', 8, 'A');

statement ok
PRAGMA ivm_options('memory', 'main', 'cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
1	Widget	10
3	Doohickey	5
4	Thingamajig	8

# --- Insert: NOT matching filter (price >= 20) ---
statement ok
INSERT INTO products VALUES (5, 'Expensive', 50, 'B');

statement ok
PRAGMA ivm_options('memory', 'main', 'cheap_products');

# MV unchanged (filtered out)
query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
1	Widget	10
3	Doohickey	5
4	Thingamajig	8

# --- Delete: row that was in the view ---
statement ok
DELETE FROM products WHERE id = 1;

statement ok
PRAGMA ivm_options('memory', 'main', 'cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8

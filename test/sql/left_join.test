  SELECT * FROM tflj_cast_mv
  EXCEPT ALL (SELECT s AS wid, COUNT(c.C_ID) AS cust_count FROM generate_series(1, 5) t(s) LEFT JOIN tflj_cust c ON c.C_W_ID = t.s GROUP BY s)

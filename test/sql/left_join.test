# ==========================================
# LEFT JOIN aggregate: incremental MERGE (Larson & Zhou)
# Tests NULL↔value transitions with openivm_match_count
# ==========================================

statement ok
CREATE TABLE lj_cust (id INT, name VARCHAR);

statement ok
CREATE TABLE lj_ord (id INT, cust_id INT, amount INT);

statement ok
INSERT INTO lj_cust VALUES (1,'Alice'), (2,'Bob'), (3,'Carol');

statement ok
INSERT INTO lj_ord VALUES (1,1,100), (2,1,200), (3,2,150);

statement ok
CREATE MATERIALIZED VIEW mv_lj_agg AS
    SELECT c.name, SUM(o.amount) as total, COUNT(o.amount) as cnt
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id
    GROUP BY c.name;

# Initial: Carol has NULL total, cnt=0 (no orders)
query III
SELECT name, total, cnt FROM mv_lj_agg ORDER BY name;
----
Alice	300	2
Bob	150	1
Carol	NULL	0

# --- NULL→value transition: insert order for Carol ---
statement ok
INSERT INTO lj_ord VALUES (4,3,500);

statement ok
PRAGMA refresh('mv_lj_agg');

query I
SELECT count(*) FROM (
    SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
    EXCEPT ALL SELECT * FROM mv_lj_agg
);
----
0

query I
SELECT count(*) FROM (
    SELECT * FROM mv_lj_agg
    EXCEPT ALL SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
);
----
0

# --- value→NULL transition: delete Carol's orders ---
statement ok
DELETE FROM lj_ord WHERE cust_id = 3;

statement ok
PRAGMA refresh('mv_lj_agg');

# Carol should still exist with NULL/0
query III
SELECT name, total, cnt FROM mv_lj_agg ORDER BY name;
----
Alice	300	2
Bob	150	1
Carol	NULL	0

query I
SELECT count(*) FROM (
    SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
    EXCEPT ALL SELECT * FROM mv_lj_agg
);
----
0

query I
SELECT count(*) FROM (
    SELECT * FROM mv_lj_agg
    EXCEPT ALL SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name

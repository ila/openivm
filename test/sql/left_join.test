# ============================================================
# Mixed joins: INNER + LEFT in same query
# ============================================================

statement ok
CREATE TABLE departments (id INT, dept_name VARCHAR);

statement ok
CREATE TABLE employees (id INT, dept_id INT, emp_name VARCHAR);

statement ok
CREATE TABLE bonuses (emp_id INT, bonus INT);

statement ok
INSERT INTO departments VALUES (1, 'Eng'), (2, 'Sales');

statement ok
INSERT INTO employees VALUES (1, 1, 'Alice'), (2, 1, 'Bob'), (3, 2, 'Charlie');

statement ok
INSERT INTO bonuses VALUES (1, 1000);

statement ok
CREATE MATERIALIZED VIEW emp_bonus AS
    SELECT e.emp_name, d.dept_name, b.bonus
    FROM employees e
    INNER JOIN departments d ON e.dept_id = d.id
    LEFT JOIN bonuses b ON e.id = b.emp_id;

statement ok
INSERT INTO bonuses VALUES (2, 500);

statement ok
PRAGMA refresh('emp_bonus');

query I
SELECT COUNT(*) FROM (
    SELECT e.emp_name, d.dept_name, b.bonus
    FROM employees e INNER JOIN departments d ON e.dept_id = d.id LEFT JOIN bonuses b ON e.id = b.emp_id
    EXCEPT ALL
    SELECT emp_name, dept_name, bonus FROM emp_bonus
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT emp_name, dept_name, bonus FROM emp_bonus
    EXCEPT ALL
    SELECT e.emp_name, d.dept_name, b.bonus
    FROM employees e INNER JOIN departments d ON e.dept_id = d.id LEFT JOIN bonuses b ON e.id = b.emp_id
);
----
0

# ============================================================
# NULL join keys in LEFT JOIN
# NULL != NULL in join, so NULL keys never match
# ============================================================

statement ok
CREATE TABLE lj_l (id INT, name VARCHAR);

statement ok
CREATE TABLE lj_r (ref_id INT, val INT);

statement ok
INSERT INTO lj_l VALUES (1, 'a'), (NULL, 'b'), (3, 'c');

statement ok
INSERT INTO lj_r VALUES (1, 100), (NULL, 200);

statement ok
CREATE MATERIALIZED VIEW lj_null_keys AS
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id;

statement ok
PRAGMA refresh('lj_null_keys');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_null_keys
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_null_keys
    EXCEPT ALL
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
);
----
0


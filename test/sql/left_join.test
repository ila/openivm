query I
SELECT COUNT(*) FROM (
    SELECT c.name, o.product, o.amount FROM customers c LEFT JOIN orders o ON c.id = o.customer_id
    EXCEPT ALL
    SELECT * FROM customer_orders
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM customer_orders
    EXCEPT ALL
    SELECT c.name, o.product, o.amount FROM customers c LEFT JOIN orders o ON c.id = o.customer_id
);
----
0


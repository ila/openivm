# --- Fallback: disable flag, should use group-recompute ---
statement ok
SET openivm_left_join_merge = false;

statement ok
INSERT INTO lj_ord VALUES (8,3,100);

statement ok
PRAGMA refresh('mv_lj_agg');

query I
SELECT count(*) FROM (
    SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
    EXCEPT ALL SELECT * FROM mv_lj_agg
);
----
0

statement ok
SET openivm_left_join_merge = true;

# --- COUNT(*) on unmatched groups survives no-op UPDATE (q0059 regression) ---
# Bug: the LJ MERGE applied `CASE mc_new > 0 THEN update ELSE null_val` to
# count_star, zeroing it on unmatched groups. But count_star counts the
# NULL-padded LJ output rows and is left-side-driven — it must not be reset
# when match_count stays at 0. Ensures an UPDATE on an unmatched left-side
# row's non-key column doesn't zero count_star.

statement ok
CREATE TABLE lj_left (k INT, extra INT);

statement ok
CREATE TABLE lj_right (k INT, v INT);

statement ok
INSERT INTO lj_left VALUES (1,10), (2,20), (3,30);

statement ok
INSERT INTO lj_right VALUES (1,100);

statement ok
CREATE MATERIALIZED VIEW mv_lj_cstar AS
    SELECT l.k, COUNT(*) AS n
    FROM lj_left l LEFT JOIN lj_right r ON l.k = r.k
    GROUP BY l.k;

query I
SELECT count(*) FROM (
    SELECT * FROM mv_lj_cstar
    EXCEPT ALL SELECT l.k, COUNT(*) FROM lj_left l LEFT JOIN lj_right r ON l.k = r.k GROUP BY l.k
);
----
0

query I
SELECT count(*) FROM (
    SELECT l.k, COUNT(*) FROM lj_left l LEFT JOIN lj_right r ON l.k = r.k GROUP BY l.k
    EXCEPT ALL SELECT * FROM mv_lj_cstar
);
----
0

statement ok
UPDATE lj_left SET extra = 200 WHERE k = 2;

statement ok
PRAGMA refresh('mv_lj_cstar');

query I
SELECT count(*) FROM (
    SELECT * FROM mv_lj_cstar
    EXCEPT ALL SELECT l.k, COUNT(*) FROM lj_left l LEFT JOIN lj_right r ON l.k = r.k GROUP BY l.k
);
----
0

query I
SELECT count(*) FROM (
    SELECT l.k, COUNT(*) FROM lj_left l LEFT JOIN lj_right r ON l.k = r.k GROUP BY l.k
    EXCEPT ALL SELECT * FROM mv_lj_cstar
);
----
0

statement ok
UPDATE lj_left SET extra = 300 WHERE k = 1;

statement ok
PRAGMA refresh('mv_lj_cstar');

query I
SELECT count(*) FROM (
    SELECT * FROM mv_lj_cstar
    EXCEPT ALL SELECT l.k, COUNT(*) FROM lj_left l LEFT JOIN lj_right r ON l.k = r.k GROUP BY l.k
);
----
0

query I
SELECT count(*) FROM (
    SELECT l.k, COUNT(*) FROM lj_left l LEFT JOIN lj_right r ON l.k = r.k GROUP BY l.k
    EXCEPT ALL SELECT * FROM mv_lj_cstar
);
----
0

# Fix E — LEFT/RIGHT/OUTER JOIN aggregate with COALESCE-wrapped aggregate or
# non-pass-through projection. The Larson & Zhou MERGE assumes raw
# SUM(NULL)=NULL semantics when match_count=0, which produces the wrong value
# for SUM(COALESCE(x, 0)) (expects 0) or COALESCE(SUM(x), 0) (expects 0 at
# the wrapper). The parser detects non-BCR aggregate arguments or non-BCR
# projection expressions over aggregate output and routes these to
# group-recompute (found_minmax=true).

# query_1502 shape: COALESCE wraps the SUM in the projection.
statement ok
CREATE TABLE fixe_stock (sw INT, si INT, sq INT);

statement ok
INSERT INTO fixe_stock VALUES (1, 100, 10), (1, 200, 20), (2, 100, 30);

statement ok
CREATE TABLE fixe_ol (olw INT, oli INT, oln INT, olq INT);

statement ok
INSERT INTO fixe_ol VALUES (1, 100, 1, 5), (1, 100, 2, 3);

statement ok
CREATE MATERIALIZED VIEW fixe_mv AS SELECT s.sw, s.si, s.sq, COUNT(ol.oln) AS sales, COALESCE(SUM(ol.olq), 0) AS ordered FROM fixe_stock s LEFT JOIN fixe_ol ol ON s.si = ol.oli AND s.sw = ol.olw GROUP BY s.sw, s.si, s.sq;

statement ok
INSERT INTO fixe_ol VALUES (2, 100, 1, 100);

statement ok
INSERT INTO fixe_stock VALUES (1, 300, 40);

statement ok
UPDATE fixe_ol SET olq = 7 WHERE oli = 100 AND olw = 1 AND oln = 1;

statement ok
DELETE FROM fixe_ol WHERE oli = 100 AND olw = 1 AND oln = 2;

statement ok
PRAGMA refresh('fixe_mv');

query I
SELECT count(*) FROM (SELECT * FROM fixe_mv EXCEPT ALL SELECT s.sw, s.si, s.sq, COUNT(ol.oln), COALESCE(SUM(ol.olq), 0) FROM fixe_stock s LEFT JOIN fixe_ol ol ON s.si = ol.oli AND s.sw = ol.olw GROUP BY s.sw, s.si, s.sq);
----
0

query I
SELECT count(*) FROM (SELECT s.sw, s.si, s.sq, COUNT(ol.oln), COALESCE(SUM(ol.olq), 0) FROM fixe_stock s LEFT JOIN fixe_ol ol ON s.si = ol.oli AND s.sw = ol.olw GROUP BY s.sw, s.si, s.sq EXCEPT ALL SELECT * FROM fixe_mv);
----
0

# query_1696/1699 shape: SUM(COALESCE(h.col, 0)) + AVG(h.col) — COALESCE
# inside the aggregate argument, plus AVG on the same null-padded column.
statement ok
CREATE TABLE fixe_c (cid INT, cw INT);

statement ok
INSERT INTO fixe_c VALUES (100, 1), (101, 1), (200, 2);

statement ok
CREATE TABLE fixe_h (hcid INT, hcw INT, hamt DECIMAL(6,2));

statement ok
INSERT INTO fixe_h VALUES (100, 1, 50), (100, 1, 25);

statement ok
CREATE MATERIALIZED VIEW fixe_mv2 AS SELECT c.cid, COUNT(*) AS n, SUM(COALESCE(h.hamt, 0)) AS tot, AVG(h.hamt) AS avg_val FROM fixe_c c LEFT JOIN fixe_h h ON c.cid = h.hcid AND c.cw = h.hcw GROUP BY c.cid;

statement ok
INSERT INTO fixe_h VALUES (101, 1, 30);

statement ok
INSERT INTO fixe_c VALUES (201, 2);

statement ok
UPDATE fixe_h SET hamt = 60 WHERE hcid = 100 AND hamt = 50;

statement ok
DELETE FROM fixe_h WHERE hcid = 100 AND hamt = 25;

statement ok
PRAGMA refresh('fixe_mv2');

query I
SELECT count(*) FROM (SELECT * FROM fixe_mv2 EXCEPT ALL SELECT c.cid, COUNT(*), SUM(COALESCE(h.hamt, 0))::DECIMAL(38,2), AVG(h.hamt)::DOUBLE FROM fixe_c c LEFT JOIN fixe_h h ON c.cid = h.hcid AND c.cw = h.hcw GROUP BY c.cid);
----
0

query I
SELECT count(*) FROM (SELECT c.cid, COUNT(*), SUM(COALESCE(h.hamt, 0))::DECIMAL(38,2), AVG(h.hamt)::DOUBLE FROM fixe_c c LEFT JOIN fixe_h h ON c.cid = h.hcid AND c.cw = h.hcw GROUP BY c.cid EXCEPT ALL SELECT * FROM fixe_mv2);
----
0


# ============================================================
# Multi-LEFT-JOIN cascade: deeper-right delta must propagate
# (regression — pre-fix the global DemoteLeftJoins collapsed
# every LJ in the IE term to INNER, so a Δ in the rightmost
# table never reached openivm_left_key for keys whose intermediate
# LJ produced NULL — the affected rows stayed stale.)
# ============================================================

statement ok
CREATE TABLE mlc_base (k INT, v INT);

statement ok
CREATE TABLE mlc_d1 (k INT, x1 INT);

statement ok
CREATE TABLE mlc_d2 (k INT, x2 INT);

statement ok
CREATE TABLE mlc_d3 (k INT, x3 INT);

statement ok
INSERT INTO mlc_base VALUES (1, 10), (2, 20);

statement ok
INSERT INTO mlc_d1 VALUES (1, 1);

statement ok
INSERT INTO mlc_d2 VALUES (1, 2);

statement ok
INSERT INTO mlc_d3 VALUES (1, 3);

statement ok
CREATE MATERIALIZED VIEW mlc_mv AS
    SELECT b.k, b.v, mlc_d1.x1, mlc_d2.x2, mlc_d3.x3
    FROM mlc_base b
    LEFT JOIN mlc_d1 ON b.k = mlc_d1.k
    LEFT JOIN mlc_d2 ON b.k = mlc_d2.k
    LEFT JOIN mlc_d3 ON b.k = mlc_d3.k;

# Deeper-right Δ for an existing-but-unmatched base key:
#   k=2 has no d1/d2/d3 row → MV row was (2,20,NULL,NULL,NULL).
#   After inserting matching rows in d2 only, MV row should
#   become (2,20,NULL,22,NULL).
statement ok
INSERT INTO mlc_d2 VALUES (2, 22);

statement ok
PRAGMA refresh('mlc_mv');

query I
SELECT COUNT(*) FROM (
    SELECT b.k, b.v, mlc_d1.x1, mlc_d2.x2, mlc_d3.x3
    FROM mlc_base b LEFT JOIN mlc_d1 ON b.k = mlc_d1.k
    LEFT JOIN mlc_d2 ON b.k = mlc_d2.k LEFT JOIN mlc_d3 ON b.k = mlc_d3.k
    EXCEPT ALL SELECT * FROM mlc_mv
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mlc_mv
    EXCEPT ALL
    SELECT b.k, b.v, mlc_d1.x1, mlc_d2.x2, mlc_d3.x3
    FROM mlc_base b LEFT JOIN mlc_d1 ON b.k = mlc_d1.k
    LEFT JOIN mlc_d2 ON b.k = mlc_d2.k LEFT JOIN mlc_d3 ON b.k = mlc_d3.k
);
----
0


# name: test/sql/ivm_checker.test
# description: Test IVM compatibility checker — classifies views as incremental or full refresh
# group: [sql]

require openivm

# ==========================================
# Setup base tables
# ==========================================

statement ok
CREATE TABLE t1 (a INT, b INT);

statement ok
CREATE TABLE t2 (a INT, c INT);

statement ok
INSERT INTO t1 VALUES (1, 10), (2, 20);

statement ok
INSERT INTO t2 VALUES (1, 100), (2, 200);

# ==========================================
# Unsupported joins → auto full refresh (no error)
# ==========================================

statement ok
CREATE MATERIALIZED VIEW mv_left AS SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a;

query III
SELECT a, b, c FROM mv_left ORDER BY a;
----
1	10	100
2	20	200

# RIGHT JOIN (rewritten to LEFT by DuckDB)
statement ok
CREATE MATERIALIZED VIEW mv_right AS SELECT t1.a, t1.b, t2.c FROM t1 RIGHT JOIN t2 ON t1.a = t2.a;

# ==========================================
# Unsupported aggregates → auto full refresh
# ==========================================

statement ok
CREATE MATERIALIZED VIEW mv_stddev AS SELECT a, STDDEV(b) AS sd FROM t1 GROUP BY a;

statement ok
CREATE MATERIALIZED VIEW mv_string_agg AS SELECT STRING_AGG(a::VARCHAR, ',') AS all_a FROM t1;

# ==========================================
# Non-deterministic functions → auto full refresh
# ==========================================

statement ok
CREATE TABLE t3 (x INT);

statement ok
INSERT INTO t3 VALUES (1), (2), (3);

statement ok
CREATE MATERIALIZED VIEW mv_random AS SELECT x, RANDOM() AS r FROM t3;

statement ok
CREATE MATERIALIZED VIEW mv_now AS SELECT x, NOW() AS ts FROM t3;

# ==========================================
# Supported constructs → incremental
# ==========================================

statement ok
CREATE MATERIALIZED VIEW mv_inner AS SELECT t1.a, t1.b, t2.c FROM t1 INNER JOIN t2 ON t1.a = t2.a;

statement ok
CREATE MATERIALIZED VIEW mv_sum AS SELECT a, SUM(b) AS total FROM t1 GROUP BY a;

statement ok
CREATE MATERIALIZED VIEW mv_avg AS SELECT a, AVG(b) AS avg_b FROM t1 GROUP BY a;

statement ok
CREATE MATERIALIZED VIEW mv_count AS SELECT COUNT(*) AS cnt FROM t1;

statement ok
CREATE MATERIALIZED VIEW mv_proj AS SELECT a, b FROM t1;

statement ok
CREATE MATERIALIZED VIEW mv_filter AS SELECT a, b FROM t1 WHERE b > 5;

# ==========================================
# Full refresh works for unsupported MVs
# ==========================================

statement ok
INSERT INTO t1 VALUES (3, 30);

statement ok
INSERT INTO t2 VALUES (3, 300);

statement ok
INSERT INTO t3 VALUES (4);

# LEFT JOIN MV: auto full refresh via PRAGMA ivm
statement ok
PRAGMA ivm('mv_left');

query III
SELECT a, b, c FROM mv_left ORDER BY a;
----
1	10	100
2	20	200
3	30	300

# Cross-check
query III
SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a ORDER BY t1.a;
----
1	10	100
2	20	200
3	30	300

# STDDEV MV: auto full refresh
statement ok
PRAGMA ivm('mv_stddev');

query I
SELECT COUNT(*) FROM (
    SELECT a, STDDEV(b) AS sd FROM t1 GROUP BY a
    EXCEPT ALL
    SELECT a, sd FROM mv_stddev
);
----
0

# RANDOM() MV: full refresh (values will differ from base query, but row count matches)
statement ok
PRAGMA ivm('mv_random');

query I
SELECT COUNT(*) FROM mv_random;
----
4

# NOW() MV: full refresh
statement ok
PRAGMA ivm('mv_now');

query I
SELECT COUNT(*) FROM mv_now;
----
4

# ==========================================
# Incremental refresh still works for supported MVs
# ==========================================

statement ok
PRAGMA ivm('mv_sum');

query II
SELECT a, total FROM mv_sum ORDER BY a;
----
1	10
2	20
3	30

# Cross-check
query I
SELECT COUNT(*) FROM (SELECT a, SUM(b) AS total FROM t1 GROUP BY a EXCEPT ALL SELECT a, total FROM mv_sum);
----
0

statement ok
PRAGMA ivm('mv_avg');

query I
SELECT COUNT(*) FROM (SELECT a, AVG(b) AS avg_b FROM t1 GROUP BY a EXCEPT ALL SELECT a, avg_b FROM mv_avg);
----
0

statement ok
PRAGMA ivm('mv_proj');

query I
SELECT COUNT(*) FROM (SELECT a, b FROM t1 EXCEPT ALL SELECT a, b FROM mv_proj);
----
0

query I
SELECT COUNT(*) FROM (SELECT a, b FROM mv_proj EXCEPT ALL SELECT a, b FROM t1);
----
0

# ==========================================
# UNION ALL — incremental support
# ==========================================

statement ok
CREATE TABLE u1 (id INT, val VARCHAR);

statement ok
CREATE TABLE u2 (id INT, val VARCHAR);

statement ok
INSERT INTO u1 VALUES (1, 'a'), (2, 'b');

statement ok
INSERT INTO u2 VALUES (3, 'c'), (4, 'd');

statement ok
CREATE MATERIALIZED VIEW mv_union AS SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2;

query II
SELECT id, val FROM mv_union ORDER BY id;
----
1	a
2	b
3	c
4	d

# Insert into both sides
statement ok
INSERT INTO u1 VALUES (5, 'e');

statement ok
INSERT INTO u2 VALUES (6, 'f');

statement ok
PRAGMA ivm('mv_union');

# Cross-check
query I
SELECT COUNT(*) FROM (
    (SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2)
    EXCEPT ALL
    SELECT id, val FROM mv_union
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM mv_union
    EXCEPT ALL
    (SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2)
);
----
0

# Delete from one side
statement ok
DELETE FROM u1 WHERE id = 1;

statement ok
PRAGMA ivm('mv_union');

query I
SELECT COUNT(*) FROM (
    (SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2)
    EXCEPT ALL
    SELECT id, val FROM mv_union
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM mv_union
    EXCEPT ALL
    (SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2)
);
----
0

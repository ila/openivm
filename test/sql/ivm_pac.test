# name: test/sql/ivm_pac.test
# description: Test IVM with PAC (Privacy-Augmented Computation) extension
# group: [sql]

require openivm

statement ok
INSTALL 'pac';

statement ok
LOAD 'pac';

statement ok
SET pac_mi = 0;

statement ok
SET pac_seed = 42;

statement ok
SET threads = 1;

# ==========================================
# Grouped aggregate: SUM with GROUP BY
# ==========================================

statement ok
CREATE PU TABLE scores (id INT, grp INT, value INT, PAC_KEY(id), protected(value));

statement ok
INSERT INTO scores VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30);

statement ok
CREATE MATERIALIZED VIEW mv_grp AS (SELECT grp, SUM(value) AS total FROM scores GROUP BY grp);

# Verify initial MV matches fresh query (IVM = no IVM)
query I
SELECT count(*) FROM (
    SELECT grp, total FROM mv_grp
    EXCEPT
    SELECT grp, SUM(value) AS total FROM scores GROUP BY grp
);
----
0

# --- Insert into existing group ---
statement ok
INSERT INTO scores VALUES (4, 2, 40);

statement ok
pragma ivm('mv_grp');

# Verify MV matches fresh query after insert (IVM = no IVM)
query I
SELECT count(*) FROM (
    SELECT grp, total FROM mv_grp
    EXCEPT
    SELECT grp, SUM(value) AS total FROM scores GROUP BY grp
);
----
0

# Also check the reverse direction
query I
SELECT count(*) FROM (
    SELECT grp, SUM(value) AS total FROM scores GROUP BY grp
    EXCEPT
    SELECT grp, total FROM mv_grp
);
----
0

# --- Delete from existing group ---
statement ok
DELETE FROM scores WHERE id = 1;

statement ok
pragma ivm('mv_grp');

# Verify MV matches fresh query after delete (IVM = no IVM)
query I
SELECT count(*) FROM (
    SELECT grp, total FROM mv_grp
    EXCEPT
    SELECT grp, SUM(value) AS total FROM scores GROUP BY grp
);
----
0

query I
SELECT count(*) FROM (
    SELECT grp, SUM(value) AS total FROM scores GROUP BY grp
    EXCEPT
    SELECT grp, total FROM mv_grp
);
----
0

# --- Mixed insert + delete ---
statement ok
INSERT INTO scores VALUES (5, 1, 50);

statement ok
DELETE FROM scores WHERE id = 3;

statement ok
pragma ivm('mv_grp');

# Verify MV matches fresh query after mixed operations (IVM = no IVM)
query I
SELECT count(*) FROM (
    SELECT grp, total FROM mv_grp
    EXCEPT
    SELECT grp, SUM(value) AS total FROM scores GROUP BY grp
);
----
0

query I
SELECT count(*) FROM (
    SELECT grp, SUM(value) AS total FROM scores GROUP BY grp
    EXCEPT
    SELECT grp, total FROM mv_grp
);
----
0

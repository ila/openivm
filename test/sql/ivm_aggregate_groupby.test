# name: test/sql/ivm_aggregate_groupby.test
# description: Test IVM with GROUP BY aggregation (sum, count)
# group: [sql]

require openivm

statement ok
CREATE TABLE sales (id INT, region VARCHAR, amount INT);

statement ok
INSERT INTO sales VALUES (1, 'east', 100), (2, 'west', 200), (3, 'east', 150);

statement ok
create materialized view sales_summary as (select region, sum(amount) as total, count(amount) as cnt from sales group by region);

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	250	2
west	200	1

# --- Insert into existing group ---
statement ok
INSERT INTO sales VALUES (4, 'east', 50);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	300	3
west	200	1

# --- Insert into new group ---
statement ok
INSERT INTO sales VALUES (5, 'north', 300);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	300	3
north	300	1
west	200	1

# --- Delete from existing group ---
statement ok
DELETE FROM sales WHERE id = 1;

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	200	1

# --- Multiple inserts in same group ---
statement ok
INSERT INTO sales VALUES (6, 'west', 75), (7, 'west', 25);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	300	3

# --- No-op PRAGMA ---
statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	300	3

# --- Batch insert into multiple groups at once ---
statement ok
INSERT INTO sales VALUES (10, 'south', 100), (11, 'south', 200), (12, 'north', 50);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region IN ('south', 'north') ORDER BY region;
----
north	350	2
south	300	2

# --- Mixed insert + delete in same cycle ---
statement ok
INSERT INTO sales VALUES (13, 'west', 100);

statement ok
DELETE FROM sales WHERE id = 6;

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region = 'west';
----
west	325	3

# --- Delete ALL rows from a group ---
statement ok
DELETE FROM sales WHERE region = 'east';

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region != 'east' ORDER BY region;
----
north	350	2
south	300	2
west	325	3

# ==========================================
# NULL values as GROUP BY keys
# ==========================================

statement ok
CREATE TABLE nullable_grp (grp VARCHAR, val INT);

statement ok
INSERT INTO nullable_grp VALUES ('a', 10), (NULL, 20), ('a', 30), (NULL, 40);

statement ok
CREATE MATERIALIZED VIEW mv_null_grp AS SELECT grp, SUM(val) AS total FROM nullable_grp GROUP BY grp;

query II
SELECT grp, total FROM mv_null_grp ORDER BY grp NULLS LAST;
----
a	40
NULL	60

statement ok
INSERT INTO nullable_grp VALUES (NULL, 5), ('b', 100);

statement ok
pragma ivm('mv_null_grp');

query II
SELECT grp, total FROM mv_null_grp ORDER BY grp NULLS LAST;
----
a	40
b	100
NULL	65

# Cross-check
query II
SELECT grp, SUM(val) FROM nullable_grp GROUP BY grp ORDER BY grp NULLS LAST;
----
a	40
b	100
NULL	65

# Delete all NULLs
statement ok
DELETE FROM nullable_grp WHERE grp IS NULL;

statement ok
pragma ivm('mv_null_grp');

query II
SELECT grp, total FROM mv_null_grp ORDER BY grp;
----
a	40
b	100

# ==========================================
# DECIMAL / NUMERIC columns in SUM
# ==========================================

statement ok
CREATE TABLE decimals (category VARCHAR, amount DECIMAL(10,2));

statement ok
INSERT INTO decimals VALUES ('x', 10.50), ('x', 20.75), ('y', 100.00);

statement ok
CREATE MATERIALIZED VIEW mv_dec AS SELECT category, SUM(amount) AS total FROM decimals GROUP BY category;

query II
SELECT category, total FROM mv_dec ORDER BY category;
----
x	31.25
y	100.00

statement ok
INSERT INTO decimals VALUES ('x', 0.01), ('y', 99.99);

statement ok
pragma ivm('mv_dec');

query II
SELECT category, total FROM mv_dec ORDER BY category;
----
x	31.26
y	199.99

# Cross-check
query II
SELECT category, SUM(amount) FROM decimals GROUP BY category ORDER BY category;
----
x	31.26
y	199.99

# ==========================================
# BIGINT columns
# ==========================================

statement ok
CREATE TABLE big_nums (grp INT, val BIGINT);

statement ok
INSERT INTO big_nums VALUES (1, 9223372036854775000), (1, 100);

statement ok
CREATE MATERIALIZED VIEW mv_big AS SELECT grp, SUM(val) AS total FROM big_nums GROUP BY grp;

query II
SELECT grp, total FROM mv_big;
----
1	9223372036854775100

statement ok
INSERT INTO big_nums VALUES (1, 500);

statement ok
pragma ivm('mv_big');

query II
SELECT grp, total FROM mv_big;
----
1	9223372036854775600

# ==========================================
# DATE columns as GROUP BY keys
# ==========================================

statement ok
CREATE TABLE daily_sales (sale_date DATE, amount INT);

statement ok
INSERT INTO daily_sales VALUES ('2024-01-01', 100), ('2024-01-01', 200), ('2024-01-02', 300);

statement ok
CREATE MATERIALIZED VIEW mv_daily AS SELECT sale_date, SUM(amount) AS total FROM daily_sales GROUP BY sale_date;

query II
SELECT sale_date, total FROM mv_daily ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	300

statement ok
INSERT INTO daily_sales VALUES ('2024-01-02', 50), ('2024-01-03', 400);

statement ok
pragma ivm('mv_daily');

query II
SELECT sale_date, total FROM mv_daily ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	350
2024-01-03	400

# Cross-check
query II
SELECT sale_date, SUM(amount) FROM daily_sales GROUP BY sale_date ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	350
2024-01-03	400

# ==========================================
# Empty table → CREATE MV → INSERT → refresh
# ==========================================

statement ok
CREATE TABLE empty_base (id INT, val INT);

statement ok
CREATE MATERIALIZED VIEW mv_empty AS SELECT id, SUM(val) AS total FROM empty_base GROUP BY id;

query II
SELECT id, total FROM mv_empty;
----

statement ok
INSERT INTO empty_base VALUES (1, 100), (2, 200);

statement ok
pragma ivm('mv_empty');

query II
SELECT id, total FROM mv_empty ORDER BY id;
----
1	100
2	200

# ==========================================
# Large batch INSERT (1000 rows)
# ==========================================

statement ok
CREATE TABLE batch_tbl (grp INT, val INT);

statement ok
CREATE MATERIALIZED VIEW mv_batch AS SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM batch_tbl GROUP BY grp;

statement ok
INSERT INTO batch_tbl SELECT i % 10, i FROM range(1000) t(i);

statement ok
pragma ivm('mv_batch');

# Cross-check
query I
SELECT COUNT(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM batch_tbl GROUP BY grp
    EXCEPT
    SELECT grp, total, cnt FROM mv_batch
);
----
0

# ==========================================
# DELETE all rows → MV should be empty
# ==========================================

statement ok
CREATE TABLE del_all (grp VARCHAR, val INT);

statement ok
INSERT INTO del_all VALUES ('a', 1), ('b', 2);

statement ok
CREATE MATERIALIZED VIEW mv_del_all AS SELECT grp, SUM(val) AS total FROM del_all GROUP BY grp;

statement ok
DELETE FROM del_all;

statement ok
pragma ivm('mv_del_all');

query II
SELECT grp, total FROM mv_del_all;
----

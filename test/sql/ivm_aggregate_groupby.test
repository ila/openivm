# name: test/sql/ivm_aggregate_groupby.test
# description: Test IVM with GROUP BY aggregation (sum, count)
# group: [sql]

require openivm

statement ok
CREATE TABLE sales (id INT, region VARCHAR, amount INT);

statement ok
INSERT INTO sales VALUES (1, 'east', 100), (2, 'west', 200), (3, 'east', 150);

statement ok
create materialized view sales_summary as (select region, sum(amount) as total, count(amount) as cnt from sales group by region);

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	250	2
west	200	1

# --- Insert into existing group ---
statement ok
INSERT INTO sales VALUES (4, 'east', 50);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	300	3
west	200	1

# --- Insert into new group ---
statement ok
INSERT INTO sales VALUES (5, 'north', 300);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	300	3
north	300	1
west	200	1

# --- Delete from existing group ---
statement ok
DELETE FROM sales WHERE id = 1;

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	200	1

# --- Multiple inserts in same group ---
statement ok
INSERT INTO sales VALUES (6, 'west', 75), (7, 'west', 25);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	300	3

# --- No-op PRAGMA ---
statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	300	3

# --- Batch insert into multiple groups at once ---
statement ok
INSERT INTO sales VALUES (10, 'south', 100), (11, 'south', 200), (12, 'north', 50);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region IN ('south', 'north') ORDER BY region;
----
north	350	2
south	300	2

# --- Mixed insert + delete in same cycle ---
statement ok
INSERT INTO sales VALUES (13, 'west', 100);

statement ok
DELETE FROM sales WHERE id = 6;

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region = 'west';
----
west	325	3

# --- Delete ALL rows from a group ---
statement ok
DELETE FROM sales WHERE region = 'east';

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region != 'east' ORDER BY region;
----
north	350	2
south	300	2
west	325	3

# name: test/sql/ivm_aggregate_groupby.test
# description: Test IVM with GROUP BY aggregation (sum, count)
# group: [sql]

require openivm

statement ok
CREATE TABLE IF NOT EXISTS _duckdb_ivm_views (view_name VARCHAR PRIMARY KEY, sql_string VARCHAR, type TINYINT, last_update TIMESTAMP);

statement ok
CREATE TABLE IF NOT EXISTS _duckdb_ivm_delta_tables (view_name VARCHAR, table_name VARCHAR, last_update TIMESTAMP, PRIMARY KEY(view_name, table_name));

# --- Base table ---
statement ok
CREATE TABLE sales (id INT, region VARCHAR, amount INT);

statement ok
INSERT INTO sales VALUES (1, 'east', 100), (2, 'west', 200), (3, 'east', 150);

# --- Materialized view: SUM + COUNT grouped by region ---
statement ok
CREATE TABLE sales_summary AS SELECT region, sum(amount) AS total, count(amount) AS cnt FROM sales GROUP BY region;

statement ok
CREATE TABLE delta_sales_summary AS SELECT *, true AS _duckdb_ivm_multiplicity FROM sales_summary LIMIT 0;

statement ok
CREATE UNIQUE INDEX sales_summary_ivm_index ON sales_summary (region);

statement ok
CREATE TABLE delta_sales AS SELECT *, true AS _duckdb_ivm_multiplicity, now()::timestamp AS _duckdb_ivm_timestamp FROM sales LIMIT 0;

statement ok
INSERT INTO _duckdb_ivm_views VALUES ('sales_summary', 'select region, sum(amount) as total, count(amount) as cnt from sales group by region', 0, now()::timestamp);

statement ok
INSERT INTO _duckdb_ivm_delta_tables VALUES ('sales_summary', 'delta_sales', '1970-01-01');

# --- Insert into existing group ---
statement ok
INSERT INTO sales VALUES (4, 'east', 50);

statement ok
PRAGMA ivm_options('memory', 'main', 'sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	300	3
west	200	1

# --- Insert into new group ---
statement ok
INSERT INTO sales VALUES (5, 'north', 300);

statement ok
PRAGMA ivm_options('memory', 'main', 'sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	300	3
north	300	1
west	200	1

# --- Delete from existing group ---
statement ok
DELETE FROM sales WHERE id = 1;

statement ok
PRAGMA ivm_options('memory', 'main', 'sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	200	1

# --- Multiple inserts in same group ---
statement ok
INSERT INTO sales VALUES (6, 'west', 75), (7, 'west', 25);

statement ok
PRAGMA ivm_options('memory', 'main', 'sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	300	3

# ==========================================
# Test 2: Aggregate with filter (WHERE clause)
# ==========================================

statement ok
CREATE TABLE orders (id INT, region VARCHAR, amount INT, status VARCHAR);

statement ok
INSERT INTO orders VALUES (1, 'east', 100, 'paid'), (2, 'west', 200, 'paid'), (3, 'east', 50, 'pending'), (4, 'west', 75, 'paid');

statement ok
CREATE TABLE paid_summary AS SELECT region, sum(amount) AS total, count(amount) AS cnt FROM orders WHERE status = 'paid' GROUP BY region;

statement ok
CREATE TABLE delta_paid_summary AS SELECT *, true AS _duckdb_ivm_multiplicity FROM paid_summary LIMIT 0;

statement ok
CREATE UNIQUE INDEX paid_summary_ivm_index ON paid_summary (region);

statement ok
CREATE TABLE delta_orders AS SELECT *, true AS _duckdb_ivm_multiplicity, now()::timestamp AS _duckdb_ivm_timestamp FROM orders LIMIT 0;

statement ok
INSERT INTO _duckdb_ivm_views VALUES ('paid_summary', 'select region, sum(amount) as total, count(amount) as cnt from orders where status = ''paid'' group by region', 0, now()::timestamp);

statement ok
INSERT INTO _duckdb_ivm_delta_tables VALUES ('paid_summary', 'delta_orders', '1970-01-01');

# Insert a paid order — should affect MV
statement ok
INSERT INTO orders VALUES (5, 'east', 60, 'paid');

statement ok
PRAGMA ivm_options('memory', 'main', 'paid_summary');

query III
SELECT region, total, cnt FROM paid_summary ORDER BY region;
----
east	160	2
west	275	2

# Insert a pending order — should NOT affect MV (filtered out)
statement ok
INSERT INTO orders VALUES (6, 'west', 300, 'pending');

statement ok
PRAGMA ivm_options('memory', 'main', 'paid_summary');

query III
SELECT region, total, cnt FROM paid_summary ORDER BY region;
----
east	160	2
west	275	2

# Delete a paid order
statement ok
DELETE FROM orders WHERE id = 2;

statement ok
PRAGMA ivm_options('memory', 'main', 'paid_summary');

query III
SELECT region, total, cnt FROM paid_summary ORDER BY region;
----
east	160	2
west	75	1

# ==========================================
# Test 3: Delete ALL rows from a group
# ==========================================

# Delete all east sales (ids 3, 4 remain in sales; id 1 already deleted)
statement ok
DELETE FROM sales WHERE region = 'east';

statement ok
PRAGMA ivm_options('memory', 'main', 'sales_summary');

# East group should have total=0 and cnt=0 (or be gone, depending on upsert)
query III
SELECT region, total, cnt FROM sales_summary WHERE region != 'east' ORDER BY region;
----
north	300	1
west	300	3

# ==========================================
# Test 4: No-op PRAGMA (no changes)
# ==========================================

statement ok
PRAGMA ivm_options('memory', 'main', 'sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region != 'east' ORDER BY region;
----
north	300	1
west	300	3

# ==========================================
# Test 5: Batch insert into multiple groups at once
# ==========================================

statement ok
INSERT INTO sales VALUES (10, 'south', 100), (11, 'south', 200), (12, 'north', 50);

statement ok
PRAGMA ivm_options('memory', 'main', 'sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region IN ('south', 'north') ORDER BY region;
----
north	350	2
south	300	2

# ==========================================
# Test 6: Mixed insert + delete in same cycle
# ==========================================

statement ok
INSERT INTO sales VALUES (13, 'west', 100);

statement ok
DELETE FROM sales WHERE id = 6;

statement ok
PRAGMA ivm_options('memory', 'main', 'sales_summary');

# west had: 200 + 75 + 25 = 300, cnt=3. Now: -75 + 100 = 325, cnt=3
query III
SELECT region, total, cnt FROM sales_summary WHERE region = 'west';
----
west	325	3

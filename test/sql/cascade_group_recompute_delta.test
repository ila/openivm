# name: test/sql/cascade_group_recompute_delta.test
# description: GROUP_RECOMPUTE emits signed cascade deltas when pragma-enabled
# group: [sql]

require openivm

statement ok
SET openivm_files_path='__TEST_DIR__';

statement ok
SET openivm_emit_cascade_delta_for_recompute=false;

statement ok
CREATE TABLE cgr_items (id INT, warehouse INT, district INT, item INT, amount INT);

statement ok
INSERT INTO cgr_items VALUES
    (1, 1, 1, 10, 5),
    (2, 1, 1, 20, 3),
    (3, 1, 1, 10, 2),
    (4, 1, 2, 30, 8),
    (5, 2, 1, 40, 1);

statement ok
CREATE MATERIALIZED VIEW cgr_mv AS
    SELECT warehouse, district,
           COUNT(DISTINCT item) AS unique_items,
           COUNT(*) AS total_lines,
           SUM(amount) AS total_amount
    FROM cgr_items
    GROUP BY warehouse, district;

query ITT
PRAGMA compile_refresh('cgr_mv');
----
6	GROUP_RECOMPUTE	<REGEX>:.*CREATE OR REPLACE TEMP TABLE openivm_affected_cgr_mv AS.*DELETE FROM .*openivm_data_cgr_mv.*INSERT INTO .*openivm_data_cgr_mv.*DROP TABLE IF EXISTS openivm_affected_cgr_mv.*

statement ok
SET openivm_emit_cascade_delta_for_recompute=true;

query ITT
PRAGMA compile_refresh('cgr_mv');
----
6	GROUP_RECOMPUTE	<REGEX>:.*CREATE OR REPLACE TEMP TABLE openivm_old_cgr_mv AS.*CREATE OR REPLACE TEMP TABLE openivm_new_cgr_mv AS.*INSERT INTO openivm_delta_cgr_mv.*CAST.*-1.*INTEGER.*CURRENT_TIMESTAMP.*UNION ALL.*CAST.*1.*INTEGER.*CURRENT_TIMESTAMP.*DROP TABLE IF EXISTS openivm_affected_cgr_mv.*DROP TABLE IF EXISTS openivm_old_cgr_mv.*DROP TABLE IF EXISTS openivm_new_cgr_mv.*

statement ok
INSERT INTO cgr_items VALUES (6, 1, 1, 50, 4);

statement ok
PRAGMA refresh('cgr_mv');

query IIIIII rowsort
SELECT warehouse, district, unique_items, total_lines, total_amount, openivm_multiplicity
FROM openivm_delta_cgr_mv;
----
1	1	2	3	10	-1
1	1	3	4	14	1

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
    EXCEPT ALL
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
    EXCEPT ALL
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
);
----
0

statement ok
DELETE FROM openivm_delta_cgr_mv;

# No-op recompute: the producer must still emit both -1 and +1 rows.
statement ok
UPDATE cgr_items SET amount = 4 WHERE id = 6;

statement ok
PRAGMA refresh('cgr_mv');

query IIIIII rowsort
SELECT warehouse, district, unique_items, total_lines, total_amount, openivm_multiplicity
FROM openivm_delta_cgr_mv;
----
1	1	3	4	14	-1
1	1	3	4	14	1

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
    EXCEPT ALL
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
    EXCEPT ALL
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
);
----
0

statement ok
DELETE FROM openivm_delta_cgr_mv;

statement ok
UPDATE cgr_items SET amount = 7 WHERE id = 6;

statement ok
PRAGMA refresh('cgr_mv');

query IIIIII rowsort
SELECT warehouse, district, unique_items, total_lines, total_amount, openivm_multiplicity
FROM openivm_delta_cgr_mv;
----
1	1	3	4	14	-1
1	1	3	4	17	1

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
    EXCEPT ALL
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
    EXCEPT ALL
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
);
----
0

statement ok
DELETE FROM openivm_delta_cgr_mv;

statement ok
DELETE FROM cgr_items WHERE id = 2;

statement ok
PRAGMA refresh('cgr_mv');

query IIIIII rowsort

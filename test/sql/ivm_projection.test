# name: test/sql/ivm_projection.test
# description: Test IVM with simple projections (no aggregation)
# group: [sql]

require openivm

statement ok
CREATE TABLE employees (id INT, name VARCHAR, dept VARCHAR);

statement ok
INSERT INTO employees VALUES (1, 'Alice', 'eng'), (2, 'Bob', 'sales');

statement ok
create materialized view emp_names as (select id, name from employees);

query II
SELECT id, name FROM emp_names ORDER BY id;
----
1	Alice
2	Bob

# --- Insert a new employee ---
statement ok
INSERT INTO employees VALUES (3, 'Charlie', 'eng');

statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
1	Alice
2	Bob
3	Charlie

# --- Delete an employee ---
statement ok
DELETE FROM employees WHERE id = 1;

statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
2	Bob
3	Charlie

# --- No-op PRAGMA ---
statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
2	Bob
3	Charlie

# --- Batch insert ---
statement ok
INSERT INTO employees VALUES (4, 'Diana', 'eng'), (5, 'Eve', 'sales');

statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
2	Bob
3	Charlie
4	Diana
5	Eve

# --- Mixed insert + delete ---
statement ok
INSERT INTO employees VALUES (6, 'Frank', 'ops');

statement ok
DELETE FROM employees WHERE id = 2;

statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
3	Charlie
4	Diana
5	Eve
6	Frank

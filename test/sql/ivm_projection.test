# name: test/sql/ivm_projection.test
# description: Test IVM with simple projections (no aggregation)
# group: [sql]

require openivm

statement ok
CREATE TABLE employees (id INT, name VARCHAR, dept VARCHAR);

statement ok
INSERT INTO employees VALUES (1, 'Alice', 'eng'), (2, 'Bob', 'sales');

statement ok
create materialized view emp_names as (select id, name from employees);

query II
SELECT id, name FROM emp_names ORDER BY id;
----
1	Alice
2	Bob

# --- Insert a new employee ---
statement ok
INSERT INTO employees VALUES (3, 'Charlie', 'eng');

statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
1	Alice
2	Bob
3	Charlie

# --- Delete an employee ---
statement ok
DELETE FROM employees WHERE id = 1;

statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
2	Bob
3	Charlie

# --- No-op PRAGMA ---
statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
2	Bob
3	Charlie

# --- Batch insert ---
statement ok
INSERT INTO employees VALUES (4, 'Diana', 'eng'), (5, 'Eve', 'sales');

statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
2	Bob
3	Charlie
4	Diana
5	Eve

# --- Mixed insert + delete ---
statement ok
INSERT INTO employees VALUES (6, 'Frank', 'ops');

statement ok
DELETE FROM employees WHERE id = 2;

statement ok
pragma ivm('emp_names');

query II
SELECT id, name FROM emp_names ORDER BY id;
----
3	Charlie
4	Diana
5	Eve
6	Frank

# ==========================================
# BOOLEAN columns in projection
# ==========================================

statement ok
CREATE TABLE flags (id INT, name VARCHAR, active BOOLEAN);

statement ok
INSERT INTO flags VALUES (1, 'Alice', true), (2, 'Bob', false);

statement ok
CREATE MATERIALIZED VIEW mv_flags AS SELECT id, name, active FROM flags;

statement ok
INSERT INTO flags VALUES (3, 'Charlie', true);

statement ok
pragma ivm('mv_flags');

query III
SELECT id, name, active FROM mv_flags ORDER BY id;
----
1	Alice	true
2	Bob	false
3	Charlie	true

statement ok
DELETE FROM flags WHERE active = false;

statement ok
pragma ivm('mv_flags');

query III
SELECT id, name, active FROM mv_flags ORDER BY id;
----
1	Alice	true
3	Charlie	true

# ==========================================
# Idempotent refresh — no changes
# ==========================================

statement ok
pragma ivm('mv_flags');

query III
SELECT id, name, active FROM mv_flags ORDER BY id;
----
1	Alice	true
3	Charlie	true

# ==========================================
# Empty table → create MV → insert → refresh
# ==========================================

statement ok
CREATE TABLE empty_proj (id INT, name VARCHAR);

statement ok
CREATE MATERIALIZED VIEW mv_empty_proj AS SELECT id, name FROM empty_proj;

query II
SELECT id, name FROM mv_empty_proj;
----

statement ok
INSERT INTO empty_proj VALUES (1, 'First'), (2, 'Second');

statement ok
pragma ivm('mv_empty_proj');

query II
SELECT id, name FROM mv_empty_proj ORDER BY id;
----
1	First
2	Second

# ==========================================
# Bag semantics stress test: duplicates, mixed DML, delta consolidation
# Every refresh is cross-checked with EXCEPT ALL in both directions.
# ==========================================

statement ok
CREATE TABLE stress (id INT, val VARCHAR);

statement ok
CREATE MATERIALIZED VIEW mv_stress AS SELECT id, val FROM stress;

# --- Round 1: Batch insert with duplicates + mixed values ---
statement ok
INSERT INTO stress VALUES (1, 'a'), (1, 'a'), (1, 'a'), (2, 'b'), (2, 'b'), (3, 'c');

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 2: More duplicates of existing + new, single refresh ---
statement ok
INSERT INTO stress VALUES (1, 'a'), (1, 'a'), (3, 'c'), (3, 'c'), (4, 'd');

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 3: Delete all of one id, keep others ---
statement ok
DELETE FROM stress WHERE id = 1;

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 4: Update all copies of a value ---
statement ok
UPDATE stress SET val = 'B' WHERE id = 2;

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 5: Mixed INSERT + DELETE + UPDATE, single refresh ---
statement ok
INSERT INTO stress VALUES (5, 'e'), (5, 'e'), (6, 'f');

statement ok
DELETE FROM stress WHERE id = 3;

statement ok
UPDATE stress SET val = 'D' WHERE id = 4;

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 6: Insert + delete same value = net zero, single refresh ---
statement ok
INSERT INTO stress VALUES (99, 'ghost'), (99, 'ghost'), (99, 'ghost');

statement ok
DELETE FROM stress WHERE id = 99;

statement ok
INSERT INTO stress VALUES (99, 'ghost');

statement ok
DELETE FROM stress WHERE id = 99;

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 7: Conflicting ops on same row — insert, delete, insert, update, insert ---
statement ok
INSERT INTO stress VALUES (30, 'x'), (30, 'x'), (30, 'x');

statement ok
DELETE FROM stress WHERE id = 30;

statement ok
INSERT INTO stress VALUES (30, 'y');

statement ok
UPDATE stress SET val = 'z' WHERE id = 30;

statement ok
INSERT INTO stress VALUES (30, 'z'), (30, 'z');

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 8: Large batch insert + delete + partial re-insert ---
statement ok
INSERT INTO stress SELECT 50, 'batch' FROM generate_series(1, 100);

statement ok
DELETE FROM stress WHERE id = 50;

statement ok
INSERT INTO stress SELECT 50, 'batch' FROM generate_series(1, 37);

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 9: Delete everything ---
statement ok
DELETE FROM stress;

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM mv_stress;
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

# --- Round 10: Re-insert after empty + no-op refresh ---
statement ok
INSERT INTO stress VALUES (10, 'z'), (10, 'z'), (11, 'w');

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# No-op
statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

# --- Round 11: Multiple updates to same rows, accumulating ---
statement ok
UPDATE stress SET val = 'z1' WHERE id = 10;

statement ok
UPDATE stress SET val = 'z2' WHERE id = 10;

statement ok
UPDATE stress SET val = 'z3' WHERE id = 10;

statement ok
INSERT INTO stress VALUES (10, 'z3');

statement ok
pragma ivm('mv_stress');

query I
SELECT COUNT(*) FROM (SELECT id, val FROM stress EXCEPT ALL SELECT id, val FROM mv_stress);
----
0

query I
SELECT COUNT(*) FROM (SELECT id, val FROM mv_stress EXCEPT ALL SELECT id, val FROM stress);
----
0

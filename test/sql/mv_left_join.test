# ============================================================
# RIGHT JOIN (DuckDB rewrites to LEFT internally)
# ============================================================

statement ok
CREATE TABLE products (id INT, pname VARCHAR);

statement ok
CREATE TABLE sales (product_id INT, qty INT);

statement ok
INSERT INTO products VALUES (1, 'Alpha'), (2, 'Beta'), (3, 'Gamma');

statement ok
INSERT INTO sales VALUES (1, 10);

statement ok
CREATE MATERIALIZED VIEW product_sales AS
    SELECT p.pname, s.qty FROM sales s RIGHT JOIN products p ON s.product_id = p.id;

statement ok
INSERT INTO sales VALUES (2, 20);

statement ok
PRAGMA ivm('product_sales');

query I
SELECT COUNT(*) FROM (
    SELECT p.pname, s.qty FROM sales s RIGHT JOIN products p ON s.product_id = p.id
    EXCEPT ALL
    SELECT pname, qty FROM product_sales
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT pname, qty FROM product_sales
    EXCEPT ALL
    SELECT p.pname, s.qty FROM sales s RIGHT JOIN products p ON s.product_id = p.id
);
----
0

# ============================================================
# LEFT JOIN with WHERE filter
# ============================================================

statement ok
CREATE TABLE items (id INT, item_name VARCHAR);

statement ok
CREATE TABLE prices (item_id INT, price INT);

statement ok
INSERT INTO items VALUES (1, 'A'), (2, 'B'), (3, 'C');

statement ok
INSERT INTO prices VALUES (1, 100);

statement ok
CREATE MATERIALIZED VIEW item_prices AS
    SELECT i.item_name, p.price
    FROM items i LEFT JOIN prices p ON i.id = p.item_id
    WHERE i.id > 0;

statement ok
INSERT INTO prices VALUES (2, 200);

statement ok
PRAGMA ivm('item_prices');

query I
SELECT COUNT(*) FROM (
    SELECT i.item_name, p.price FROM items i LEFT JOIN prices p ON i.id = p.item_id WHERE i.id > 0
    EXCEPT ALL
    SELECT item_name, price FROM item_prices
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT item_name, price FROM item_prices
    EXCEPT ALL
    SELECT i.item_name, p.price FROM items i LEFT JOIN prices p ON i.id = p.item_id WHERE i.id > 0
);
----
0

# ============================================================
# Mixed joins: INNER + LEFT in same query
# ============================================================

statement ok
CREATE TABLE departments (id INT, dept_name VARCHAR);

statement ok
CREATE TABLE employees (id INT, dept_id INT, emp_name VARCHAR);

statement ok
CREATE TABLE bonuses (emp_id INT, bonus INT);

statement ok
INSERT INTO departments VALUES (1, 'Eng'), (2, 'Sales');

statement ok
INSERT INTO employees VALUES (1, 1, 'Alice'), (2, 1, 'Bob'), (3, 2, 'Charlie');

statement ok
INSERT INTO bonuses VALUES (1, 1000);

statement ok
CREATE MATERIALIZED VIEW emp_bonus AS
    SELECT e.emp_name, d.dept_name, b.bonus
    FROM employees e
    INNER JOIN departments d ON e.dept_id = d.id
    LEFT JOIN bonuses b ON e.id = b.emp_id;

statement ok
INSERT INTO bonuses VALUES (2, 500);

statement ok
PRAGMA ivm('emp_bonus');

query I
SELECT COUNT(*) FROM (
    SELECT e.emp_name, d.dept_name, b.bonus
    FROM employees e INNER JOIN departments d ON e.dept_id = d.id LEFT JOIN bonuses b ON e.id = b.emp_id
    EXCEPT ALL
    SELECT emp_name, dept_name, bonus FROM emp_bonus
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT emp_name, dept_name, bonus FROM emp_bonus
    EXCEPT ALL
    SELECT e.emp_name, d.dept_name, b.bonus
    FROM employees e INNER JOIN departments d ON e.dept_id = d.id LEFT JOIN bonuses b ON e.id = b.emp_id
);
----
0

# ============================================================
# NULL join keys in LEFT JOIN
# NULL != NULL in join, so NULL keys never match
# ============================================================

statement ok
CREATE TABLE lj_l (id INT, name VARCHAR);

statement ok
CREATE TABLE lj_r (ref_id INT, val INT);

statement ok
INSERT INTO lj_l VALUES (1, 'a'), (NULL, 'b'), (3, 'c');

statement ok
INSERT INTO lj_r VALUES (1, 100), (NULL, 200);

statement ok
CREATE MATERIALIZED VIEW lj_null_keys AS
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id;

statement ok
PRAGMA ivm('lj_null_keys');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_null_keys
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_null_keys
    EXCEPT ALL
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
);
----
0

# Insert into right: ref_id=3 now matches left id=3
statement ok
INSERT INTO lj_r VALUES (3, 300);

statement ok
PRAGMA ivm('lj_null_keys');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_null_keys
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_null_keys
    EXCEPT ALL
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
);
----
0

# Delete from right: ref_id=1 removed, name='a' becomes NULL-extended
statement ok
DELETE FROM lj_r WHERE ref_id = 1;

statement ok
PRAGMA ivm('lj_null_keys');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_null_keys
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_null_keys
    EXCEPT ALL
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
);
----
0

# Delete from left: remove the NULL-keyed row
statement ok
DELETE FROM lj_l WHERE id IS NULL;

statement ok
PRAGMA ivm('lj_null_keys');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_null_keys
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_null_keys
    EXCEPT ALL
    SELECT l.name, r.val FROM lj_l l LEFT JOIN lj_r r ON l.id = r.ref_id
);
----
0

# ============================================================
# LEFT JOIN where entire right table is empty
# ============================================================

statement ok
CREATE TABLE lj_emp_l (id INT, name VARCHAR);

statement ok
CREATE TABLE lj_emp_r (ref_id INT, score INT);

statement ok
INSERT INTO lj_emp_l VALUES (1, 'x'), (2, 'y'), (3, 'z');

# lj_emp_r is intentionally empty — all left rows should be NULL-extended

statement ok
CREATE MATERIALIZED VIEW lj_empty_right AS
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id;

statement ok
PRAGMA ivm('lj_empty_right');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_empty_right
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_empty_right
    EXCEPT ALL
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id
);
----
0

# Insert one match — 'x' gets a real score, 'y' and 'z' still NULL-extended
statement ok
INSERT INTO lj_emp_r VALUES (1, 10);

statement ok
PRAGMA ivm('lj_empty_right');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_empty_right
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_empty_right
    EXCEPT ALL
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id
);
----
0

# Insert matches for all left rows using generate_series
statement ok
INSERT INTO lj_emp_r SELECT id, id*10 FROM generate_series(1,3) t(id);

statement ok
PRAGMA ivm('lj_empty_right');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_empty_right
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_empty_right
    EXCEPT ALL
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id
);
----
0

# Delete all from right — all rows back to NULL-extended
statement ok
DELETE FROM lj_emp_r;

statement ok
PRAGMA ivm('lj_empty_right');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id
    EXCEPT ALL
    SELECT * FROM lj_empty_right
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_empty_right
    EXCEPT ALL
    SELECT l.name, r.score FROM lj_emp_l l LEFT JOIN lj_emp_r r ON l.id = r.ref_id
);
----
0

# ==========================================
# Right side empty → repopulated with different values
# ==========================================

statement ok
CREATE TABLE lj_repop_l (id INT, name VARCHAR);

statement ok
CREATE TABLE lj_repop_r (ref_id INT, score INT);

statement ok
INSERT INTO lj_repop_l VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');

statement ok
INSERT INTO lj_repop_r VALUES (1, 100), (2, 200), (3, 300);

statement ok
CREATE MATERIALIZED VIEW lj_repop AS
    SELECT l.name, r.score FROM lj_repop_l l LEFT JOIN lj_repop_r r ON l.id = r.ref_id;

# DELETE all right side → all NULL-extended
statement ok
DELETE FROM lj_repop_r;

statement ok
PRAGMA ivm('lj_repop');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM lj_repop_l l LEFT JOIN lj_repop_r r ON l.id = r.ref_id
    EXCEPT ALL SELECT * FROM lj_repop
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_repop
    EXCEPT ALL SELECT l.name, r.score FROM lj_repop_l l LEFT JOIN lj_repop_r r ON l.id = r.ref_id
);
----
0

# Repopulate with DIFFERENT matches (only ids 1 and 3, not 2)
statement ok
INSERT INTO lj_repop_r VALUES (1, 999), (3, 777);

statement ok
PRAGMA ivm('lj_repop');

query I
SELECT COUNT(*) FROM (
    SELECT l.name, r.score FROM lj_repop_l l LEFT JOIN lj_repop_r r ON l.id = r.ref_id
    EXCEPT ALL SELECT * FROM lj_repop
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM lj_repop
    EXCEPT ALL SELECT l.name, r.score FROM lj_repop_l l LEFT JOIN lj_repop_r r ON l.id = r.ref_id
);
----
0

# ==========================================
# LEFT JOIN aggregate: incremental MERGE (Larson & Zhou)
# Tests NULL↔value transitions with _ivm_match_count
# ==========================================

statement ok
CREATE TABLE lj_cust (id INT, name VARCHAR);

statement ok
CREATE TABLE lj_ord (id INT, cust_id INT, amount INT);

statement ok
INSERT INTO lj_cust VALUES (1,'Alice'), (2,'Bob'), (3,'Carol');

statement ok
INSERT INTO lj_ord VALUES (1,1,100), (2,1,200), (3,2,150);

statement ok
CREATE MATERIALIZED VIEW mv_lj_agg AS
    SELECT c.name, SUM(o.amount) as total, COUNT(o.amount) as cnt
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id
    GROUP BY c.name;

# Initial: Carol has NULL total, cnt=0 (no orders)
query III
SELECT name, total, cnt FROM mv_lj_agg ORDER BY name;
----
Alice	300	2
Bob	150	1
Carol	NULL	0

# --- NULL→value transition: insert order for Carol ---
statement ok
INSERT INTO lj_ord VALUES (4,3,500);

statement ok
PRAGMA ivm('mv_lj_agg');

query I
SELECT count(*) FROM (
    SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
    EXCEPT ALL SELECT * FROM mv_lj_agg
);
----
0

query I
SELECT count(*) FROM (
    SELECT * FROM mv_lj_agg
    EXCEPT ALL SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
);
----
0

# --- value→NULL transition: delete Carol's orders ---
statement ok
DELETE FROM lj_ord WHERE cust_id = 3;

statement ok
PRAGMA ivm('mv_lj_agg');

# Carol should still exist with NULL/0
query III
SELECT name, total, cnt FROM mv_lj_agg ORDER BY name;
----
Alice	300	2
Bob	150	1
Carol	NULL	0

query I
SELECT count(*) FROM (
    SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
    EXCEPT ALL SELECT * FROM mv_lj_agg
);
----
0

query I
SELECT count(*) FROM (
    SELECT * FROM mv_lj_agg
    EXCEPT ALL SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
);
----
0


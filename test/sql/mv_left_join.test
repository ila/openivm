# name: test/sql/mv_left_join.test
# description: Test IVM with LEFT JOIN
# group: [sql]

require openivm

statement ok
SET ivm_cascade_refresh = 'off';

# ============================================================
# Setup
# ============================================================

statement ok
CREATE TABLE customers (id INT, name VARCHAR);

statement ok
CREATE TABLE orders (customer_id INT, product VARCHAR, amount INT);

statement ok
INSERT INTO customers VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');

statement ok
INSERT INTO orders VALUES (1, 'Widget', 100), (1, 'Gadget', 200);

statement ok
CREATE MATERIALIZED VIEW customer_orders AS
    SELECT c.name, o.product, o.amount
    FROM customers c LEFT JOIN orders o ON c.id = o.customer_id;

# Initial: Alice has 2 orders, Bob and Charlie have NULL
query III
SELECT * FROM customer_orders ORDER BY name, product NULLS LAST;
----
Alice	Gadget	200
Alice	Widget	100
Bob	NULL	NULL
Charlie	NULL	NULL

# ============================================================
# Insert into right side: Bob gets an order (NULL row should be replaced)
# ============================================================

statement ok
INSERT INTO orders VALUES (2, 'Bolt', 50);

statement ok
PRAGMA ivm('customer_orders');

query I
SELECT COUNT(*) FROM (
    SELECT c.name, o.product, o.amount FROM customers c LEFT JOIN orders o ON c.id = o.customer_id
    EXCEPT ALL
    SELECT * FROM customer_orders
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM customer_orders
    EXCEPT ALL
    SELECT c.name, o.product, o.amount FROM customers c LEFT JOIN orders o ON c.id = o.customer_id
);
----
0

# ============================================================
# Delete from right side: remove Alice's only remaining order
# (she should get a NULL row back)
# ============================================================

statement ok
DELETE FROM orders WHERE customer_id = 1 AND product = 'Widget';

statement ok
PRAGMA ivm('customer_orders');

query I
SELECT COUNT(*) FROM (
    SELECT c.name, o.product, o.amount FROM customers c LEFT JOIN orders o ON c.id = o.customer_id
    EXCEPT ALL
    SELECT * FROM customer_orders
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM customer_orders
    EXCEPT ALL
    SELECT c.name, o.product, o.amount FROM customers c LEFT JOIN orders o ON c.id = o.customer_id
);
----
0

# ============================================================
# Insert into left side (new customer with no orders → NULL extended)
# ============================================================

statement ok
INSERT INTO customers VALUES (4, 'Dave');

statement ok
PRAGMA ivm('customer_orders');

query I
SELECT COUNT(*) FROM (
    SELECT c.name, o.product, o.amount FROM customers c LEFT JOIN orders o ON c.id = o.customer_id
    EXCEPT ALL
    SELECT * FROM customer_orders
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM customer_orders
    EXCEPT ALL
    SELECT c.name, o.product, o.amount FROM customers c LEFT JOIN orders o ON c.id = o.customer_id
);
----
0


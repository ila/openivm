statement ok
INSERT INTO lj_ord VALUES (5,1,50), (6,3,200), (7,2,300);

statement ok
DELETE FROM lj_ord WHERE id = 2;

statement ok
PRAGMA ivm('mv_lj_agg');

query I
SELECT count(*) FROM (
    SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
    EXCEPT ALL SELECT * FROM mv_lj_agg
);
----
0

query I
SELECT count(*) FROM (
    SELECT * FROM mv_lj_agg
    EXCEPT ALL SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
);
----
0

# --- Fallback: disable flag, should use group-recompute ---
statement ok
SET ivm_left_join_merge = false;

statement ok
INSERT INTO lj_ord VALUES (8,3,100);

statement ok
PRAGMA ivm('mv_lj_agg');

query I
SELECT count(*) FROM (
    SELECT c.name, SUM(o.amount), COUNT(o.amount)
    FROM lj_cust c LEFT JOIN lj_ord o ON c.id = o.cust_id GROUP BY c.name
    EXCEPT ALL SELECT * FROM mv_lj_agg
);
----
0

statement ok
SET ivm_left_join_merge = true;

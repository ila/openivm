# ASOF windows whose partition key comes from the RHS match must use current/new diff:
# a newer RHS row can move existing left rows out of the old matched partition.

statement ok
CREATE TABLE oprec_asof_rhs_win_trades (symbol VARCHAR, ts TIMESTAMP, qty INT);

statement ok
CREATE TABLE oprec_asof_rhs_win_prices (symbol VARCHAR, ts TIMESTAMP, price INT);

statement ok
INSERT INTO oprec_asof_rhs_win_trades VALUES
    ('A', TIMESTAMP '2024-02-02 10:00:00', 1),
    ('A', TIMESTAMP '2024-02-02 10:20:00', 2),
    ('B', TIMESTAMP '2024-02-02 10:15:00', 3);

statement ok
INSERT INTO oprec_asof_rhs_win_prices VALUES
    ('A', TIMESTAMP '2024-02-02 09:00:00', 100),
    ('A', TIMESTAMP '2024-02-02 10:10:00', 110),
    ('B', TIMESTAMP '2024-02-02 10:00:00', 200);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_asof_rhs_window AS
    SELECT
        symbol,
        trade_ts,
        qty,
        price,
        row_number() OVER (PARTITION BY price ORDER BY trade_ts, symbol) AS rn
    FROM (
        SELECT
            t.symbol AS symbol,
            t.ts AS trade_ts,
            t.qty AS qty,
            p.price AS price
        FROM oprec_asof_rhs_win_trades t
        ASOF JOIN oprec_asof_rhs_win_prices p
          ON t.symbol = p.symbol
         AND t.ts >= p.ts
    ) q;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_asof_rhs_window';
----
10


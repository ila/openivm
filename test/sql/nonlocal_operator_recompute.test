# ==========================================
# POSITIONAL JOIN is exact current/new diff recompute
# ==========================================

statement ok
CREATE TABLE oprec_pos_l (id INT, lval VARCHAR);

statement ok
CREATE TABLE oprec_pos_r (rid INT, rval VARCHAR);

statement ok
INSERT INTO oprec_pos_l VALUES (1, 'a'), (2, 'b'), (3, 'c');

statement ok
INSERT INTO oprec_pos_r VALUES (10, 'x'), (20, 'y');

statement ok
CREATE MATERIALIZED VIEW mv_oprec_positional AS
    SELECT
        l.id AS id,
        l.lval AS lval,
        r.rid AS rid,
        r.rval AS rval,
        row_number() OVER (
            ORDER BY
                coalesce(l.id, 1000000),
                coalesce(r.rid, 1000000)
        ) AS rn
    FROM oprec_pos_l l
    POSITIONAL JOIN oprec_pos_r r;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_positional';
----
10


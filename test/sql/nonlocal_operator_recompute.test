        l.lval AS lval,
        r.rid AS rid,
        r.rval AS rval,
        row_number() OVER (
            ORDER BY
                coalesce(l.id, 1000000),
                coalesce(r.rid, 1000000)
        ) AS rn
    FROM oprec_pos_l l
    POSITIONAL JOIN oprec_pos_r r
    EXCEPT ALL
    SELECT id, lval, rid, rval, rn FROM mv_oprec_positional
);
----
0


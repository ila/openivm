# ==========================================
# SAMPLE is exact current/new diff recompute, not a local delta
# ==========================================

statement ok
CREATE TABLE oprec_sample (id INT, grp INT, v INT);

statement ok
INSERT INTO oprec_sample VALUES
    (1, 1, 10),
    (2, 1, 20),
    (3, 1, 30),
    (4, 2, 40),
    (5, 2, 50),
    (6, 2, 60);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_sample AS
    SELECT
        id,
        grp,
        v,
        row_number() OVER (PARTITION BY grp ORDER BY v DESC, id) AS rn
    FROM oprec_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (17);

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_sample';
----
10

statement ok
INSERT INTO oprec_sample VALUES (7, 1, 70), (8, 3, 80);

statement ok
DELETE FROM oprec_sample WHERE id = 2;

statement ok
UPDATE oprec_sample SET v = 15 WHERE id = 1;

statement ok
PRAGMA refresh('mv_oprec_sample');

query I
SELECT count(*) FROM (
    SELECT
        id,
        grp,
        v,
        row_number() OVER (PARTITION BY grp ORDER BY v DESC, id) AS rn
    FROM oprec_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (17)
    EXCEPT ALL
    SELECT id, grp, v, rn FROM mv_oprec_sample
);
----
0

query I
SELECT count(*) FROM (
    SELECT id, grp, v, rn FROM mv_oprec_sample
    EXCEPT ALL
    SELECT
        id,
        grp,
        v,
        row_number() OVER (PARTITION BY grp ORDER BY v DESC, id) AS rn
    FROM oprec_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (17)
);
----
0


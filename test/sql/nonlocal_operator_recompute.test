# name: test/sql/nonlocal_operator_recompute.test
# description: ASOF, SAMPLE, and POSITIONAL refresh strategies
# group: [sql]

require openivm

# Top ASOF section and the materialized-CTE ASOF block moved to
# nonlocal_operator_recompute_asof.test (gated `require notwindows` — DuckDB
# parallel-ASOF deadlock on Windows). See TODO(asof-deadlock) there.


# ==========================================
# SAMPLE is exact current/new diff recompute, not a local delta
# ==========================================

statement ok
CREATE TABLE oprec_sample (id INT, grp INT, v INT);

statement ok
INSERT INTO oprec_sample VALUES
    (1, 1, 10),
    (2, 1, 20),
    (3, 1, 30),
    (4, 2, 40),
    (5, 2, 50),
    (6, 2, 60);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_sample AS
    SELECT
        id,
        grp,
        v,
        row_number() OVER (PARTITION BY grp ORDER BY v DESC, id) AS rn
    FROM oprec_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (17);

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_sample';
----
10

statement ok
INSERT INTO oprec_sample VALUES (7, 1, 70), (8, 3, 80);

statement ok
DELETE FROM oprec_sample WHERE id = 2;

statement ok
UPDATE oprec_sample SET v = 15 WHERE id = 1;

statement ok
PRAGMA refresh('mv_oprec_sample');

query I
SELECT count(*) FROM (
    SELECT
        id,
        grp,
        v,
        row_number() OVER (PARTITION BY grp ORDER BY v DESC, id) AS rn
    FROM oprec_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (17)
    EXCEPT ALL
    SELECT id, grp, v, rn FROM mv_oprec_sample
);
----
0

query I
SELECT count(*) FROM (
    SELECT id, grp, v, rn FROM mv_oprec_sample
    EXCEPT ALL
    SELECT
        id,
        grp,
        v,
        row_number() OVER (PARTITION BY grp ORDER BY v DESC, id) AS rn
    FROM oprec_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (17)
);
----
0

# Volatile samples keep the existing full-refresh behavior.

statement ok
CREATE TABLE oprec_sample_volatile (id INT);

statement ok
INSERT INTO oprec_sample_volatile VALUES (1), (2), (3);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_sample_volatile AS
    SELECT id FROM oprec_sample_volatile USING SAMPLE reservoir(1 ROWS);

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_sample_volatile';
----
3

# ==========================================
# POSITIONAL JOIN is exact current/new diff recompute
# ==========================================

statement ok
CREATE TABLE oprec_pos_l (id INT, lval VARCHAR);

statement ok
CREATE TABLE oprec_pos_r (rid INT, rval VARCHAR);

statement ok
INSERT INTO oprec_pos_l VALUES (1, 'a'), (2, 'b'), (3, 'c');

statement ok
INSERT INTO oprec_pos_r VALUES (10, 'x'), (20, 'y');

statement ok
CREATE MATERIALIZED VIEW mv_oprec_positional AS
    SELECT
        l.id AS id,
        l.lval AS lval,
        r.rid AS rid,
        r.rval AS rval,
        row_number() OVER (
            ORDER BY
                coalesce(l.id, 1000000),
                coalesce(r.rid, 1000000)
        ) AS rn
    FROM oprec_pos_l l
    POSITIONAL JOIN oprec_pos_r r;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_positional';
----
10

statement ok
INSERT INTO oprec_pos_l VALUES (4, 'd');

statement ok
DELETE FROM oprec_pos_r WHERE rid = 20;

statement ok
UPDATE oprec_pos_l SET lval = 'aa' WHERE id = 1;

statement ok
PRAGMA refresh('mv_oprec_positional');

query I
SELECT count(*) FROM (
    SELECT
        l.id AS id,
        l.lval AS lval,
        r.rid AS rid,
        r.rval AS rval,
        row_number() OVER (
            ORDER BY
                coalesce(l.id, 1000000),
                coalesce(r.rid, 1000000)
        ) AS rn
    FROM oprec_pos_l l
    POSITIONAL JOIN oprec_pos_r r
    EXCEPT ALL
    SELECT id, lval, rid, rval, rn FROM mv_oprec_positional
);
----
0

query I
SELECT count(*) FROM (
    SELECT id, lval, rid, rval, rn FROM mv_oprec_positional
    EXCEPT ALL
    SELECT
        l.id AS id,
        l.lval AS lval,
        r.rid AS rid,
        r.rval AS rval,
        row_number() OVER (
            ORDER BY
                coalesce(l.id, 1000000),
                coalesce(r.rid, 1000000)
        ) AS rn
    FROM oprec_pos_l l
    POSITIONAL JOIN oprec_pos_r r
);
----
0

# ==========================================
# Hidden non-local operators inside materialized CTEs are still classified conservatively
# ==========================================

# (materialized-CTE ASOF block moved to nonlocal_operator_recompute_asof.test)

statement ok
CREATE TABLE oprec_cte_sample (id INT, grp INT, v INT);

statement ok
INSERT INTO oprec_cte_sample VALUES
    (1, 1, 10),
    (2, 1, 20),
    (3, 1, 30),
    (4, 2, 40),
    (5, 2, 50),
    (6, 3, 60);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_cte_sample AS
    WITH sampled AS MATERIALIZED (
        SELECT id, grp, v
        FROM oprec_cte_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (23)
    )
    SELECT grp, COUNT(*) AS cnt, SUM(v) AS total_v
    FROM sampled
    GROUP BY grp;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_cte_sample';
----
10

statement ok
INSERT INTO oprec_cte_sample VALUES (7, 2, 70), (8, 4, 80);

statement ok
DELETE FROM oprec_cte_sample WHERE id = 2;

statement ok
UPDATE oprec_cte_sample SET v = 15 WHERE id = 1;

statement ok
PRAGMA refresh('mv_oprec_cte_sample');

query I
SELECT count(*) FROM (
    WITH sampled AS MATERIALIZED (
        SELECT id, grp, v
        FROM oprec_cte_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (23)
    )
    SELECT grp, COUNT(*) AS cnt, SUM(v) AS total_v
    FROM sampled
    GROUP BY grp
    EXCEPT ALL
    SELECT grp, cnt, total_v FROM mv_oprec_cte_sample
);
----
0

query I
WITH sampled AS MATERIALIZED (
    SELECT id, grp, v
    FROM oprec_cte_sample USING SAMPLE reservoir(4 ROWS) REPEATABLE (23)
)
SELECT count(*) FROM (
    SELECT grp, cnt, total_v FROM mv_oprec_cte_sample
    EXCEPT ALL
    SELECT grp, COUNT(*) AS cnt, SUM(v) AS total_v
    FROM sampled
    GROUP BY grp
);
----
0

statement ok
CREATE TABLE oprec_cte_pos_l (id INT, lval INT);

statement ok
CREATE TABLE oprec_cte_pos_r (rid INT, rval INT);

statement ok
INSERT INTO oprec_cte_pos_l VALUES (1, 10), (2, 20), (3, 30);

statement ok
INSERT INTO oprec_cte_pos_r VALUES (10, 100), (20, 200);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_cte_positional AS
    WITH paired AS MATERIALIZED (
        SELECT l.id AS id, l.lval AS lval, r.rid AS rid, r.rval AS rval
        FROM oprec_cte_pos_l l
        POSITIONAL JOIN oprec_cte_pos_r r
    )
    SELECT
        COUNT(*) AS cnt,
        SUM(coalesce(id, 0) + coalesce(rid, 0)) AS total_ids,
        SUM(coalesce(lval, 0) + coalesce(rval, 0)) AS total_vals
    FROM paired;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_cte_positional';
----
10

statement ok
INSERT INTO oprec_cte_pos_l VALUES (4, 40);

statement ok
DELETE FROM oprec_cte_pos_r WHERE rid = 20;

statement ok
UPDATE oprec_cte_pos_l SET lval = 15 WHERE id = 1;

statement ok
PRAGMA refresh('mv_oprec_cte_positional');

query I
SELECT count(*) FROM (
    WITH paired AS MATERIALIZED (
        SELECT l.id AS id, l.lval AS lval, r.rid AS rid, r.rval AS rval
        FROM oprec_cte_pos_l l
        POSITIONAL JOIN oprec_cte_pos_r r
    )
    SELECT
        COUNT(*) AS cnt,
        SUM(coalesce(id, 0) + coalesce(rid, 0)) AS total_ids,
        SUM(coalesce(lval, 0) + coalesce(rval, 0)) AS total_vals
    FROM paired
    EXCEPT ALL
    SELECT cnt, total_ids, total_vals FROM mv_oprec_cte_positional
);
----
0

query I
WITH paired AS MATERIALIZED (
    SELECT l.id AS id, l.lval AS lval, r.rid AS rid, r.rval AS rval
    FROM oprec_cte_pos_l l
    POSITIONAL JOIN oprec_cte_pos_r r
)
SELECT count(*) FROM (
    SELECT cnt, total_ids, total_vals FROM mv_oprec_cte_positional
    EXCEPT ALL
    SELECT
        COUNT(*) AS cnt,
        SUM(coalesce(id, 0) + coalesce(rid, 0)) AS total_ids,
        SUM(coalesce(lval, 0) + coalesce(rval, 0)) AS total_vals
    FROM paired
);
----
0

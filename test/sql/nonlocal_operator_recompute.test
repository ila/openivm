# name: test/sql/nonlocal_operator_recompute.test
# description: ASOF, SAMPLE, and POSITIONAL refresh strategies
# group: [sql]

require openivm

# ==========================================
# ASOF projections use exact current/new diff recompute
# ==========================================

statement ok
CREATE TABLE oprec_asof_trades (symbol VARCHAR, ts TIMESTAMP, qty INT);

statement ok
CREATE TABLE oprec_asof_prices (symbol VARCHAR, ts TIMESTAMP, price INT);

statement ok
INSERT INTO oprec_asof_trades VALUES
    ('A', TIMESTAMP '2024-01-01 10:00:00', 1),
    ('A', TIMESTAMP '2024-01-01 10:20:00', 2),
    ('B', TIMESTAMP '2024-01-01 10:15:00', 3);

statement ok
INSERT INTO oprec_asof_prices VALUES
    ('A', TIMESTAMP '2024-01-01 09:00:00', 100),
    ('A', TIMESTAMP '2024-01-01 10:18:00', 180),
    ('B', TIMESTAMP '2024-01-01 10:12:00', 120);

statement ok
CREATE MATERIALIZED VIEW mv_oprec_asof_projection AS
    SELECT
        t.symbol AS symbol,
        t.ts AS trade_ts,
        t.qty AS qty,
        p.ts AS price_ts,
        p.price AS price
    FROM oprec_asof_trades t
    ASOF JOIN oprec_asof_prices p
      ON t.symbol = p.symbol
     AND t.ts >= p.ts;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_asof_projection';
----
10

statement ok
INSERT INTO oprec_asof_prices VALUES ('A', TIMESTAMP '2024-01-01 10:19:00', 190);

statement ok
INSERT INTO oprec_asof_trades VALUES ('A', TIMESTAMP '2024-01-01 10:21:00', 4);

statement ok
DELETE FROM oprec_asof_prices WHERE symbol = 'B' AND ts = TIMESTAMP '2024-01-01 10:12:00';

statement ok
UPDATE oprec_asof_trades SET qty = 6 WHERE symbol = 'A' AND ts = TIMESTAMP '2024-01-01 10:00:00';

statement ok
PRAGMA refresh('mv_oprec_asof_projection');

query I
SELECT count(*) FROM (
    SELECT
        t.symbol AS symbol,
        t.ts AS trade_ts,
        t.qty AS qty,
        p.ts AS price_ts,
        p.price AS price
    FROM oprec_asof_trades t
    ASOF JOIN oprec_asof_prices p
      ON t.symbol = p.symbol
     AND t.ts >= p.ts
    EXCEPT ALL
    SELECT symbol, trade_ts, qty, price_ts, price FROM mv_oprec_asof_projection
);
----
0

query I
SELECT count(*) FROM (
    SELECT symbol, trade_ts, qty, price_ts, price FROM mv_oprec_asof_projection
    EXCEPT ALL
    SELECT
        t.symbol AS symbol,
        t.ts AS trade_ts,
        t.qty AS qty,
        p.ts AS price_ts,
        p.price AS price
    FROM oprec_asof_trades t
    ASOF JOIN oprec_asof_prices p
      ON t.symbol = p.symbol
     AND t.ts >= p.ts
);
----
0

# Grouped ASOF outputs use group recompute with current/new affected keys.

statement ok
CREATE MATERIALIZED VIEW mv_oprec_asof_group AS
    SELECT
        t.symbol AS symbol,
        COUNT(*) AS cnt,
        SUM(p.price) AS total_price
    FROM oprec_asof_trades t
    ASOF JOIN oprec_asof_prices p
      ON t.symbol = p.symbol
     AND t.ts >= p.ts
    GROUP BY t.symbol;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_oprec_asof_group';
----
6

query T
SELECT group_recompute_affected_mode FROM openivm_views WHERE view_name = 'mv_oprec_asof_group';
----
current_diff

statement ok
INSERT INTO oprec_asof_prices VALUES ('B', TIMESTAMP '2024-01-01 10:00:00', 130);

statement ok
INSERT INTO oprec_asof_prices VALUES ('A', TIMESTAMP '2024-01-01 10:20:00', 200);

statement ok
DELETE FROM oprec_asof_trades WHERE symbol = 'A' AND ts = TIMESTAMP '2024-01-01 10:00:00';

statement ok
UPDATE oprec_asof_trades SET qty = 5 WHERE symbol = 'A' AND ts = TIMESTAMP '2024-01-01 10:21:00';

statement ok
PRAGMA refresh('mv_oprec_asof_group');

query I
SELECT count(*) FROM (
    SELECT
        t.symbol AS symbol,
        COUNT(*) AS cnt,
        SUM(p.price) AS total_price
    FROM oprec_asof_trades t
    ASOF JOIN oprec_asof_prices p
      ON t.symbol = p.symbol
     AND t.ts >= p.ts
    GROUP BY t.symbol
    EXCEPT ALL
    SELECT symbol, cnt, total_price FROM mv_oprec_asof_group
);
----
0

query I
SELECT count(*) FROM (
    SELECT symbol, cnt, total_price FROM mv_oprec_asof_group
    EXCEPT ALL
    SELECT
        t.symbol AS symbol,
        COUNT(*) AS cnt,
        SUM(p.price) AS total_price
    FROM oprec_asof_trades t
    ASOF JOIN oprec_asof_prices p
      ON t.symbol = p.symbol
     AND t.ts >= p.ts
    GROUP BY t.symbol
);

# name: test/sql/ivm_aggregate.test
# description: Test IVM with all aggregate types (SUM, COUNT, MIN, MAX, AVG, grouped and ungrouped)
# group: [sql]

require openivm

statement ok
CREATE TABLE sales (id INT, region VARCHAR, amount INT);

statement ok
INSERT INTO sales VALUES (1, 'east', 100), (2, 'west', 200), (3, 'east', 150);

statement ok
create materialized view sales_summary as (select region, sum(amount) as total, count(amount) as cnt from sales group by region);

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	250	2
west	200	1

# --- Insert into existing group ---
statement ok
INSERT INTO sales VALUES (4, 'east', 50);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	300	3
west	200	1

# --- Insert into new group ---
statement ok
INSERT INTO sales VALUES (5, 'north', 300);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	300	3
north	300	1
west	200	1

# --- Delete from existing group ---
statement ok
DELETE FROM sales WHERE id = 1;

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	200	1

# --- Multiple inserts in same group ---
statement ok
INSERT INTO sales VALUES (6, 'west', 75), (7, 'west', 25);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	300	3

# --- No-op PRAGMA ---
statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary ORDER BY region;
----
east	200	2
north	300	1
west	300	3

# --- Batch insert into multiple groups at once ---
statement ok
INSERT INTO sales VALUES (10, 'south', 100), (11, 'south', 200), (12, 'north', 50);

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region IN ('south', 'north') ORDER BY region;
----
north	350	2
south	300	2

# --- Mixed insert + delete in same cycle ---
statement ok
INSERT INTO sales VALUES (13, 'west', 100);

statement ok
DELETE FROM sales WHERE id = 6;

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region = 'west';
----
west	325	3

# --- Delete ALL rows from a group ---
statement ok
DELETE FROM sales WHERE region = 'east';

statement ok
pragma ivm('sales_summary');

query III
SELECT region, total, cnt FROM sales_summary WHERE region != 'east' ORDER BY region;
----
north	350	2
south	300	2
west	325	3

# ==========================================
# NULL values as GROUP BY keys
# ==========================================

statement ok
CREATE TABLE nullable_grp (grp VARCHAR, val INT);

statement ok
INSERT INTO nullable_grp VALUES ('a', 10), (NULL, 20), ('a', 30), (NULL, 40);

statement ok
CREATE MATERIALIZED VIEW mv_null_grp AS SELECT grp, SUM(val) AS total FROM nullable_grp GROUP BY grp;

query II
SELECT grp, total FROM mv_null_grp ORDER BY grp NULLS LAST;
----
a	40
NULL	60

statement ok
INSERT INTO nullable_grp VALUES (NULL, 5), ('b', 100);

statement ok
pragma ivm('mv_null_grp');

query II
SELECT grp, total FROM mv_null_grp ORDER BY grp NULLS LAST;
----
a	40
b	100
NULL	65

# Cross-check
query II
SELECT grp, SUM(val) FROM nullable_grp GROUP BY grp ORDER BY grp NULLS LAST;
----
a	40
b	100
NULL	65

# Delete all NULLs
statement ok
DELETE FROM nullable_grp WHERE grp IS NULL;

statement ok
pragma ivm('mv_null_grp');

query II
SELECT grp, total FROM mv_null_grp ORDER BY grp;
----
a	40
b	100

# ==========================================
# DECIMAL / NUMERIC columns in SUM
# ==========================================

statement ok
CREATE TABLE decimals (category VARCHAR, amount DECIMAL(10,2));

statement ok
INSERT INTO decimals VALUES ('x', 10.50), ('x', 20.75), ('y', 100.00);

statement ok
CREATE MATERIALIZED VIEW mv_dec AS SELECT category, SUM(amount) AS total FROM decimals GROUP BY category;

query II
SELECT category, total FROM mv_dec ORDER BY category;
----
x	31.25
y	100.00

statement ok
INSERT INTO decimals VALUES ('x', 0.01), ('y', 99.99);

statement ok
pragma ivm('mv_dec');

query II
SELECT category, total FROM mv_dec ORDER BY category;
----
x	31.26
y	199.99

# Cross-check
query II
SELECT category, SUM(amount) FROM decimals GROUP BY category ORDER BY category;
----
x	31.26
y	199.99

